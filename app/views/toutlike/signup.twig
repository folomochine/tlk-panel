{% extends 'public_base.twig' %}
{% block title %}{{ site['site_name'] }} - Inscription{% endblock %}
{% block extra_css %}
.signup-shell{max-width:1180px;margin:0 auto}
.signup-grid{display:grid;grid-template-columns:minmax(0,1.05fr) minmax(380px,460px);gap:28px;align-items:center}
.signup-copy,.signup-card{position:relative;z-index:1}
.signup-badge{
  display:inline-flex;align-items:center;gap:8px;padding:8px 14px;border-radius:999px;
  background:rgba(91,140,255,.12);border:1px solid rgba(91,140,255,.18);
  color:#bfd6ff;font-size:12px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;margin-bottom:18px;
}
body.light .signup-badge{color:#365ea8}
.signup-title{
  font-size:clamp(34px,5vw,58px);line-height:1.02;font-weight:900;letter-spacing:-.05em;
  margin-bottom:18px;color:var(--text);max-width:720px;
}
.signup-title span{
  background:linear-gradient(135deg,var(--primary),var(--accent),var(--primary-2));
  -webkit-background-clip:text;background-clip:text;color:transparent;
}
.signup-text{max-width:620px;color:var(--muted);font-size:16px;line-height:1.85;margin-bottom:24px}
.signup-points{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px;margin-bottom:24px}
.signup-point{
  display:flex;gap:14px;padding:16px 18px;border-radius:20px;background:rgba(255,255,255,.04);border:1px solid var(--border);
}
.point-icon{
  width:46px;height:46px;border-radius:16px;flex-shrink:0;display:flex;align-items:center;justify-content:center;
  background:linear-gradient(135deg,rgba(91,140,255,.22),rgba(124,92,252,.24));border:1px solid rgba(124,92,252,.18);color:#fff;
}
.point-icon svg{width:20px;height:20px;display:block}
.point-copy strong{display:block;font-size:14px;font-weight:800;color:var(--text);margin-bottom:4px}
.point-copy span{display:block;color:var(--muted);font-size:12px;line-height:1.7}
.signup-strip{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}
.signup-stat{
  padding:18px;border-radius:20px;background:rgba(255,255,255,.04);border:1px solid var(--border);
}
.signup-stat strong{display:block;font-size:15px;font-weight:800;color:var(--text);margin-bottom:6px}
.signup-stat span{display:block;color:var(--muted);font-size:12px;line-height:1.7}
.signup-card{
  overflow:hidden;border-radius:28px;border:1px solid var(--border-strong);background:var(--card2);
  box-shadow:var(--shadow),inset 0 1px 0 rgba(255,255,255,.04);backdrop-filter:blur(18px);
}
.signup-card::before{
  content:"";position:absolute;inset:0;pointer-events:none;
  background:linear-gradient(160deg,rgba(91,140,255,.12),transparent 40%),linear-gradient(330deg,rgba(124,92,252,.11),transparent 36%);
}
.signup-inner{position:relative;z-index:1;padding:28px}
.signup-top{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:18px}
.signup-chip{
  display:inline-flex;align-items:center;gap:8px;padding:8px 12px;border-radius:999px;
  background:rgba(255,255,255,.05);border:1px solid var(--border);font-size:11px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:#c8d7f0;
}
body.light .signup-chip{color:#47617f}
.signup-dot{width:12px;height:12px;border-radius:50%;background:var(--success);box-shadow:0 0 0 8px rgba(34,197,94,.14)}
.signup-card h2{font-size:30px;line-height:1.08;font-weight:900;letter-spacing:-.04em;color:var(--text);margin-bottom:8px}
.signup-sub{color:var(--muted);font-size:14px;line-height:1.8;margin-bottom:22px}
.row2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.terms{
  display:flex;align-items:flex-start;gap:10px;margin:18px 0 20px;font-size:13px;color:var(--muted);line-height:1.7;
}
.terms input{width:16px;height:16px;accent-color:var(--primary);margin-top:3px;flex-shrink:0}
.terms a{font-weight:700}
.signup-submit{
  width:100%;height:54px;border:none;border-radius:18px;cursor:pointer;color:#fff;font-size:15px;font-weight:800;
  background:linear-gradient(135deg,var(--primary),var(--primary-2));transition:.22s ease;box-shadow:0 16px 30px rgba(91,140,255,.24);
}
.signup-submit:hover{transform:translateY(-2px);box-shadow:0 18px 32px rgba(91,140,255,.3)}
.signup-note{display:flex;align-items:center;gap:10px;margin-top:14px;color:var(--muted);font-size:12px;line-height:1.7}
.signup-note strong{color:var(--text)}
.signup-note-dot{width:11px;height:11px;border-radius:999px;background:linear-gradient(135deg,var(--success),#86efac);flex-shrink:0}
.signup-google{
  width:100%;height:52px;border-radius:18px;border:1px solid var(--input-b);background:rgba(255,255,255,.04);color:var(--text);
  font-size:14px;font-weight:700;display:flex;align-items:center;justify-content:center;gap:10px;transition:.2s ease;text-decoration:none;
}
.signup-google:hover{border-color:var(--border-strong);background:rgba(91,140,255,.08)}
.signup-login{text-align:center;margin-top:18px;padding-top:16px;border-top:1px solid var(--border);color:var(--muted);font-size:13px}
.signup-login a{font-weight:800}
@media(max-width:1080px){
  .signup-grid{grid-template-columns:1fr}
}
@media(max-width:768px){
  .signup-points,.signup-strip,.row2{grid-template-columns:1fr}
  .signup-inner{padding:22px 18px}
}
{% endblock %}
{% block content %}
<div class="signup-shell">
  <div class="signup-grid">
    <div class="signup-copy anim d1">
      <div class="signup-badge">TikTok · Facebook · Instagram · YouTube</div>
      <h1 class="signup-title">Créez votre compte et <span>boostez vos réseaux</span> en 2 minutes</h1>
      <p class="signup-text">Inscrivez-vous pour commander des likes, followers, vues et commentaires depuis la Guinée. Paiement Orange Money, livraison rapide et démarrage immédiat sur TikTok, Facebook, Instagram et YouTube.</p>

      <div class="signup-points">
        <div class="signup-point">
          <div class="point-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M2 12h20"/></svg>
          </div>
          <div class="point-copy">
            <strong>Livraison ~2 min</strong>
            <span>Les commandes démarrent rapidement après validation pour vous faire gagner du temps.</span>
          </div>
        </div>
        <div class="signup-point">
          <div class="point-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 10h18"/></svg>
          </div>
          <div class="point-copy">
            <strong>Paiement Orange Money</strong>
            <span>Recharge en GNF adaptée au marché local sans carte bancaire obligatoire.</span>
          </div>
        </div>
        <div class="signup-point">
          <div class="point-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
          </div>
          <div class="point-copy">
            <strong>4 plateformes couvertes</strong>
            <span>TikTok, Facebook, Instagram et YouTube dans une seule interface simple.</span>
          </div>
        </div>
        <div class="signup-point">
          <div class="point-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3l7 4v5c0 5-3.5 7.5-7 9-3.5-1.5-7-4-7-9V7l7-4z"/></svg>
          </div>
          <div class="point-copy">
            <strong>+10 000 clients</strong>
            <span>Des créateurs et commerçants en Guinée utilisent déjà nos services chaque semaine.</span>
          </div>
        </div>
      </div>

      <div class="signup-strip">
        <div class="signup-stat">
          <strong>100% mobile</strong>
          <span>L'expérience est pensée d'abord pour le téléphone, là où la majorité des clients commandent.</span>
        </div>
        <div class="signup-stat">
          <strong>Prix imbattables</strong>
          <span>Des tarifs compétitifs pour des likes, followers et vues adaptés au marché local.</span>
        </div>
        <div class="signup-stat">
          <strong>Support 24/7</strong>
          <span>Un souci ? L'équipe reste disponible par ticket pour vous accompagner rapidement.</span>
        </div>
      </div>
    </div>

    <div class="signup-card anim d2">
      <div class="signup-inner">
        <div class="signup-top">
          <div class="signup-chip">Inscription</div>
          <div class="signup-dot"></div>
        </div>

        <h2>Créer un compte</h2>
        <p class="signup-sub">Remplissez le formulaire pour commencer à commander des likes, followers et vues sur TikTok, Facebook, Instagram et YouTube.</p>

        {% if error %}<div class="alert alert-d">{{ errorText }}</div>{% endif %}
        {% if success %}<div class="alert alert-s">{{ successText }}</div>{% endif %}

        <form method="post" action="/signup/signup" id="signupForm">
          {{ csrf_field() }}

          <div class="fg">
            <label for="username">Nom d'utilisateur</label>
            <input type="text" id="username" name="username" placeholder="Ex: mamadou224" value="{{ data['username'] }}" required>
          </div>

          <div class="fg">
            <label for="email">Adresse e-mail</label>
            <input type="email" id="email" name="email" placeholder="votre@email.com" value="{{ data['email'] }}" required>
          </div>


          <div class="row2">
            <div class="fg">
              <label for="password">Mot de passe</label>
              <input type="password" id="password" name="password" placeholder="8 caractères minimum" required>
            </div>
            <div class="fg">
              <label for="password_again">Confirmer</label>
              <input type="password" id="password_again" name="password_again" placeholder="Retapez le mot de passe" required>
            </div>
          </div>

          {% if captcha %}
            <div class="fg">
              <div class="g-recaptcha" data-sitekey="{{ captchaKey }}"></div>
              <script src="https://www.google.com/recaptcha/api.js" async defer></script>
            </div>
          {% endif %}

          <div class="terms">
            <input type="checkbox" name="terms" id="terms" value="1" required>
            <label for="terms">J'accepte les <a href="/terms" target="_blank">Conditions d'utilisation</a> de {{ site['site_name'] }}.</label>
          </div>

          <button type="submit" class="signup-submit">Créer mon compte</button>

          <div class="signup-note">
            <span class="signup-note-dot"></span>
            <span><strong>Inscription gratuite</strong> — commencez à commander dès que votre compte est créé.</span>
          </div>
        </form>

        {% if google_login_content %}
          <div style="display:flex;align-items:center;gap:12px;margin:18px 0;color:var(--dim);font-size:12px;text-transform:uppercase;letter-spacing:.12em;font-weight:700">
            <span style="flex:1;height:1px;background:var(--border)"></span>ou<span style="flex:1;height:1px;background:var(--border)"></span>
          </div>
          <a href="?login-with-google" class="signup-google">
            <svg width="18" height="18" viewBox="0 0 18 18"><path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.874 2.684-6.615z" fill="#4285F4"/><path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 009 18z" fill="#34A853"/><path d="M3.964 10.71A5.41 5.41 0 013.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 000 9c0 1.452.348 2.827.957 4.042l3.007-2.332z" fill="#FBBC05"/><path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 00.957 4.958L3.964 6.29C4.672 4.163 6.656 3.58 9 3.58z" fill="#EA4335"/></svg>
            S'inscrire avec Google
          </a>
        {% endif %}

        <div class="signup-login">Déjà un compte ? <a href="/">Se connecter</a></div>
      </div>
    </div>
  </div>
</div>
{% endblock %}