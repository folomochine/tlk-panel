{# Template de base pour les pages publiques (non connecté) #}
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}{{ site['site_name'] }}{% endblock %}</title>
  <meta name="description" content="{{ pagedescription ? pagedescription : site['description'] }}">
  <meta name="keywords" content="{{ pagekeywords ? pagekeywords : site['keywords'] }}">
  <link rel="icon" href="{{ site['favicon'] }}" type="image/png">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --bg:#060b17;--bg2:#091223;--bg3:#101c34;
      --card:#0f1729;--card2:rgba(15,23,41,.78);--soft:#111c31;
      --border:rgba(148,163,184,.16);--border-strong:rgba(124,92,252,.26);
      --primary:#5b8cff;--primary-2:#7c5cfc;--accent:#67e8f9;--success:#22c55e;
      --text:#f8fbff;--muted:#98a9c0;--dim:#6f8298;
      --input:#13203a;--input-b:#233557;--shadow:0 20px 60px rgba(0,0,0,.28);
      --radius:24px;--radius-sm:18px;
    }
    html{scroll-behavior:smooth}
    body{
      font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
      background:
        radial-gradient(circle at top left,rgba(91,140,255,.16),transparent 28%),
        radial-gradient(circle at top right,rgba(124,92,252,.13),transparent 25%),
        linear-gradient(180deg,var(--bg) 0%,var(--bg2) 54%,var(--bg) 100%);
      color:var(--text);
      line-height:1.6;
      overflow-x:hidden;
    }
    body.light{
      --bg:#f4f7fb;--bg2:#eef3fa;--bg3:#ffffff;
      --card:#ffffff;--card2:rgba(255,255,255,.82);--soft:#f7f9fc;
      --border:rgba(15,23,42,.09);--border-strong:rgba(91,140,255,.22);
      --text:#0f172a;--muted:#5c6f86;--dim:#8192a8;
      --input:#f7f9fd;--input-b:#d8e0ee;
      background:
        radial-gradient(circle at top left,rgba(91,140,255,.10),transparent 28%),
        radial-gradient(circle at top right,rgba(124,92,252,.08),transparent 25%),
        linear-gradient(180deg,#f5f8fd 0%,#edf3fb 55%,#f6f9fd 100%);
    }
    a{color:var(--primary);text-decoration:none}
    a:hover{text-decoration:none}
    .shell{max-width:1180px;margin:0 auto;padding:0 20px}
    .container{max-width:860px;margin:0 auto}
    .container-lg{max-width:1180px;margin:0 auto}

    .site-nav{
      position:fixed;top:0;left:0;right:0;z-index:100;
      backdrop-filter:blur(18px);
      background:rgba(6,11,23,.72);
      border-bottom:1px solid var(--border);
    }
    body.light .site-nav{background:rgba(255,255,255,.8)}
    .nav-inner{
      height:78px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:18px;
    }
    .brand{display:flex;align-items:center;gap:12px;min-width:0}
    .brand img{height:38px;display:block}
    .brand-mark{
      width:42px;height:42px;border-radius:14px;
      display:flex;align-items:center;justify-content:center;
      background:linear-gradient(135deg,rgba(91,140,255,.18),rgba(124,92,252,.2));
      border:1px solid var(--border);
      box-shadow:0 12px 24px rgba(91,140,255,.15);
      color:#fff;font-weight:800;font-size:15px;
    }
    .nav-links{display:flex;align-items:center;gap:8px}
    .nav-link{
      padding:10px 14px;border-radius:999px;font-size:13px;font-weight:600;
      color:var(--muted);transition:.2s ease;
    }
    .nav-link:hover{color:var(--text);background:rgba(255,255,255,.04)}
    .nav-actions{display:flex;align-items:center;gap:10px}
    .theme-toggle,.burger{
      width:42px;height:42px;border-radius:14px;border:1px solid var(--border);
      background:rgba(255,255,255,.04);color:var(--muted);cursor:pointer;
      display:inline-flex;align-items:center;justify-content:center;transition:.2s ease;
      font-size:16px;
    }
    .theme-toggle:hover,.burger:hover{color:var(--text);border-color:var(--border-strong)}
    .btn-outline,.btn-fill{
      display:inline-flex;align-items:center;justify-content:center;gap:8px;
      padding:11px 18px;border-radius:14px;font-size:13px;font-weight:700;transition:.22s ease;
    }
    .btn-outline{border:1px solid var(--border);color:var(--text);background:rgba(255,255,255,.04)}
    .btn-outline:hover{border-color:var(--border-strong);color:var(--primary)}
    .btn-fill{
      color:#fff;
      background:linear-gradient(135deg,var(--primary),var(--primary-2));
      box-shadow:0 14px 28px rgba(91,140,255,.24);
    }
    .btn-fill:hover{transform:translateY(-2px);box-shadow:0 18px 30px rgba(91,140,255,.3)}
    .burger{display:none}

    .mob-menu{
      display:none;position:fixed;top:79px;left:16px;right:16px;z-index:99;
      padding:16px;border-radius:22px;background:var(--card2);border:1px solid var(--border);
      box-shadow:var(--shadow);backdrop-filter:blur(18px);
      flex-direction:column;gap:10px;
    }
    .mob-menu.open{display:flex}
    .mob-menu a{padding:12px 14px;border-radius:14px;color:var(--muted);font-size:14px;font-weight:600;background:rgba(255,255,255,.03)}
    .mob-menu a:hover{color:var(--text);background:rgba(91,140,255,.08)}

    .page{
      position:relative;
      min-height:100vh;
      padding:126px 20px 64px;
    }
    .page::before,
    .page::after{
      content:"";position:absolute;pointer-events:none;filter:blur(70px);opacity:.42;
    }
    .page::before{
      width:260px;height:260px;left:0;top:110px;
      background:radial-gradient(circle,rgba(91,140,255,.24) 0%,transparent 72%);
    }
    .page::after{
      width:220px;height:220px;right:0;bottom:120px;
      background:radial-gradient(circle,rgba(124,92,252,.2) 0%,transparent 72%);
    }

    .page-header{position:relative;z-index:1;text-align:center;margin-bottom:38px}
    .page-header h1{
      color:var(--text);font-size:clamp(30px,5vw,52px);line-height:1.04;font-weight:900;letter-spacing:-.05em;margin-bottom:14px;
    }
    .page-header p{color:var(--muted);font-size:15px;line-height:1.85;max-width:720px;margin:0 auto}

    .card{
      position:relative;z-index:1;overflow:hidden;
      background:var(--card2);border:1px solid var(--border);border-radius:var(--radius);
      padding:28px 24px;margin-bottom:18px;
      box-shadow:var(--shadow),inset 0 1px 0 rgba(255,255,255,.04);
      backdrop-filter:blur(18px);
    }
    .card::before{
      content:"";position:absolute;inset:0;pointer-events:none;
      background:linear-gradient(160deg,rgba(91,140,255,.08),transparent 40%),linear-gradient(330deg,rgba(124,92,252,.08),transparent 36%);
    }
    .card > *{position:relative;z-index:1}
    .card h2{color:var(--text);font-size:24px;font-weight:800;line-height:1.15;letter-spacing:-.03em;margin-bottom:12px}
    .card h3{color:var(--text)}
    .card p{color:var(--muted)}

    .alert{padding:12px 14px;border-radius:16px;margin-bottom:14px;font-size:13px;font-weight:600}
    .alert-d{background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.2);color:#fca5a5}
    .alert-s{background:rgba(34,197,94,.1);border:1px solid rgba(34,197,94,.2);color:#86efac}

    .fg{margin-bottom:15px}
    .fg label{
      display:block;margin-bottom:7px;color:var(--muted);font-size:12px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;
    }
    .fg input[type=text],.fg input[type=email],.fg input[type=password],.fg input[type=tel],.fg textarea,.fg select{
      width:100%;min-height:52px;padding:14px 16px;background:var(--input);border:1px solid var(--input-b);
      border-radius:18px;color:var(--text);font-size:14px;outline:none;transition:.22s ease;font-family:inherit;
    }
    .fg textarea{min-height:130px;resize:vertical}
    .fg input:focus,.fg textarea:focus,.fg select:focus{
      border-color:var(--border-strong);box-shadow:0 0 0 4px rgba(91,140,255,.12)
    }
    .fg input::placeholder,.fg textarea::placeholder{color:var(--dim)}

    .btn,.btn-full{
      display:inline-flex;align-items:center;justify-content:center;gap:8px;
      min-height:52px;padding:14px 24px;border:none;border-radius:18px;
      background:linear-gradient(135deg,var(--primary),var(--primary-2));color:#fff;
      font-size:14px;font-weight:800;cursor:pointer;text-decoration:none;transition:.22s ease;
      box-shadow:0 14px 28px rgba(91,140,255,.24);
    }
    .btn:hover,.btn-full:hover{transform:translateY(-2px);box-shadow:0 18px 30px rgba(91,140,255,.3)}
    .btn-full{width:100%}

    .badge-sm{
      display:inline-flex;align-items:center;justify-content:center;padding:6px 10px;border-radius:999px;
      background:rgba(91,140,255,.1);border:1px solid rgba(91,140,255,.16);font-size:11px;color:#c7d9ff;font-weight:800;letter-spacing:.08em;
    }
    body.light .badge-sm{color:#3c5ea1}

    table{width:100%;border-collapse:separate;border-spacing:0}
    th,td{padding:14px 16px;text-align:left;border-bottom:1px solid var(--border);font-size:13px}
    th{color:var(--muted);font-weight:800;font-size:11px;text-transform:uppercase;letter-spacing:.12em;background:rgba(255,255,255,.03)}
    td{color:var(--text);background:rgba(255,255,255,.01)}
    tr:hover td{background:rgba(91,140,255,.05)}

    .faq-item{background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:20px;margin-bottom:12px;overflow:hidden}
    .faq-q{padding:18px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;font-weight:800;font-size:14px;transition:.2s;color:var(--text)}
    .faq-q:hover{color:var(--primary)}
    .faq-q .arr{transition:.3s;color:var(--dim)}
    .faq-item.open .faq-q .arr{transform:rotate(180deg);color:var(--primary)}
    .faq-a{max-height:0;overflow:hidden;transition:.3s ease;padding:0 18px}
    .faq-item.open .faq-a{max-height:320px;padding:0 18px 18px}
    .faq-a p{font-size:13px;color:var(--muted);line-height:1.8}

    .blog-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:18px}
    .blog-card{
      background:var(--card2);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;transition:.24s ease;
      box-shadow:var(--shadow),inset 0 1px 0 rgba(255,255,255,.04);backdrop-filter:blur(18px);
    }
    .blog-card:hover{border-color:var(--border-strong);transform:translateY(-4px)}
    .blog-card img{width:100%;height:220px;object-fit:cover;display:block}
    .blog-card .content{padding:20px}
    .blog-card h3{font-size:18px;font-weight:800;color:var(--text);margin-bottom:10px;line-height:1.3}
    .blog-card p{font-size:13px;color:var(--muted);line-height:1.8}

    .search-box{display:flex;gap:10px;margin-bottom:20px}
    .search-box input{flex:1}
    .search-box select{width:auto;min-width:160px}

    footer{border-top:1px solid var(--border);padding:26px 0 34px;color:var(--dim);font-size:12px}
    .footer-inner{display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap}
    .footer-links{display:flex;align-items:center;gap:16px;flex-wrap:wrap}
    .footer-links a{color:var(--muted);font-size:12px;font-weight:600}
    .footer-links a:hover{color:var(--primary)}

    @keyframes fu{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
    .anim{animation:fu .6s ease forwards}

    @media(max-width:980px){
      .nav-links,.nav-actions .btn-outline,.nav-actions .btn-fill{display:none}
      .burger{display:inline-flex}
      .blog-grid{grid-template-columns:1fr 1fr}
    }
    @media(max-width:768px){
      .page{padding:110px 16px 42px}
      .shell{padding:0 14px}
      .container,.container-lg{max-width:100%}
      .card{padding:22px 18px}
      .search-box{flex-direction:column}
      .blog-grid{grid-template-columns:1fr}
      .page-header{margin-bottom:28px}
      .page-header h1{font-size:clamp(28px,9vw,42px)}
      .page-header p{font-size:14px}
      .mob-menu{top:74px;left:14px;right:14px}
      .nav-inner{height:72px}
      .footer-inner{flex-direction:column;align-items:flex-start}
    }
    {% block extra_css %}{% endblock %}
  </style>
  {{ headerCode|raw }}
</head>
<body>

<nav class="site-nav">
  <div class="shell nav-inner">
    <a href="/" class="brand" aria-label="{{ site['site_name'] }}">
      {% if site['logo'] %}
        <img src="{{ site['logo'] }}" alt="{{ site['site_name'] }}">
      {% else %}
        <span class="brand-mark">{{ site['site_name']|slice(0,2)|upper }}</span>
      {% endif %}
    </a>

    <div class="nav-links">
      <a href="/services" class="nav-link">Services</a>
      <a href="/about-us" class="nav-link">À propos</a>
      <a href="/blog" class="nav-link">Blog</a>
      <a href="/contact-us" class="nav-link">Contact</a>
      <a href="/faq" class="nav-link">FAQ</a>
    </div>

    <div class="nav-actions">
      <button class="theme-toggle" onclick="toggleTheme()" title="Mode clair / sombre">☼</button>
      <a href="/" class="btn-outline">Connexion</a>
      {% if Signup %}<a href="/signup" class="btn-fill">S'inscrire</a>{% endif %}
      <button class="burger" onclick="toggleMobileMenu()" aria-label="Menu">☰</button>
    </div>
  </div>
</nav>

<div class="mob-menu" id="mobMenu">
  <a href="/services">Services</a>
  <a href="/about-us">À propos</a>
  <a href="/blog">Blog</a>
  <a href="/contact-us">Contact</a>
  <a href="/faq">FAQ</a>
  <a href="/" class="btn-outline" style="justify-content:center">Connexion</a>
  {% if Signup %}<a href="/signup" class="btn-fill" style="justify-content:center">S'inscrire</a>{% endif %}
</div>

<main class="page">
  {% block content %}{% endblock %}
</main>

<footer>
  <div class="shell footer-inner">
    <div>© {{ "now"|date("Y") }} {{ site['site_name'] }}. Tous droits réservés.</div>
    <div class="footer-links">
      <a href="/services">Services</a>
      <a href="/about-us">À propos</a>
      <a href="/blog">Blog</a>
      <a href="/contact-us">Contact</a>
      <a href="/faq">FAQ</a>
      <a href="/terms">Conditions</a>
    </div>
  </div>
</footer>
{{ footerCode|raw }}
<script>
function toggleTheme(){
  document.body.classList.toggle('light');
  var t=document.body.classList.contains('light')?'light':'dark';
  localStorage.setItem('tl_theme',t);
  var b=document.querySelector('.theme-toggle');
  if(b){ b.innerHTML=t==='light'?'☾':'☼'; }
}
(function(){
  if(localStorage.getItem('tl_theme')==='light'){
    document.body.classList.add('light');
  }
  var b=document.querySelector('.theme-toggle');
  if(b && document.body.classList.contains('light')){ b.innerHTML='☾'; }
})();
function toggleMobileMenu(){
  var m=document.getElementById('mobMenu');
  if(m){ m.classList.toggle('open'); }
}
document.querySelectorAll('.faq-q').forEach(function(el){
  el.addEventListener('click', function(){
    this.parentElement.classList.toggle('open');
  });
});
</script>
{% block scripts %}{% endblock %}
</body>
</html>