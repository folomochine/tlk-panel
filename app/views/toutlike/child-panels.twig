{% include 'header.twig' %}

<!-- Main variables *content* -->
        <main class="auth">
                    <div class="about_us_effect">
            <img
              src="https://cdn.ToutLike.com/smmscript/smmrx/img/bg-img1.png"
              class="img-fluid about_us_img_left"
              alt=""
            />
            <img
              src="https://cdn.ToutLike.com/smmscript/smmrx/img/bg-img2.png"
              class="img-fluid about_us_img_right"
              alt=""
            />
          </div>
          		    <section id="auth_banner">
  <div class="container-fluid">
    <div class="row d-flex align-items-center">
      <div class="col-lg-6 col-md-6 col-12">
        <div class="banner_content">
          <h2>
            Louez un panel enfant aujourd'hui et commencez a gagner de l'argent
          </h2>
          <p>
            Un panel enfant est un panel avec une selection limitee de fonctionnalites qui est lie a l'un de vos panels reguliers
          </p>
          <p>
            Cela vous coutera 10,00 $ par mois. Veuillez noter que vous payez pour le panel, pas pour les services, vous devez payer pour les services que vous achetez
          </p>
        </div>
      </div>
      <div class="col-lg-6 col-md-6 col-12">
        <div class="banner_image">
          <img
            src="https://cdn.ToutLike.com/smmscript/smmrx/img/l78cp62qlahba2ly.png"
            class="img-fluid"
            alt=""
          />
        </div>
      </div>
    </div>
  </div>
</section>

<section id="child-panel">
  <div class="container-fluid">
    <div class="row">
      <div class="col-lg-6 col-md-6 col-12">
        <div class="card card_auth_1 mb-3">
          <div class="card-header d-flex flex-column justify-content-center">
            <h3>Panel enfant</h3>
            <p>En entrant les informations, commandez un panel enfant.</p>
          </div>
          <div class="card-body">
                          {% if error %}
      <div class="alert alert-dismissible alert-danger">
          <button type="button" class="close" data-dismiss="alert">×</button>
        {{ errorText }}
      </div>
    {% endif %}  

    {% if data["childpanel"]["success"] == 1 %}
      <div class="alert alert-dismissible alert-success">
          <strong> ID de commande : </strong> {{ data['childpanel']['id'] }} <br>
          <strong> Service : </strong> {{ data['childpanel']['service'] }} <br>
          <strong> Domaine : </strong> {{ data['childpanel']['link'] }} <br>
          <strong> Quantite : </strong> {{ data['childpanel']['quantity'] }} <br>
          <strong> Montant : </strong> {{ data['childpanel']['price'] }} <br>
      </div>
    {% endif %}
    <form name="contact-form" action="child-panels" method="post">
                {{ csrf_field() }}
                                <div class="first">
                    <div class="form-group">
                        <label for="domain" class="control-label">Domaine</label>
                        <input type="text" class="form-control" id="domain" name="panel_domain"
                              value="">
                    </div>
                    <div class="alert alert-info">
                        <div>Veuillez changer les serveurs de noms vers :</div>
                        <ul style="padding-left: 20px">
                                                            <li>ns1.ToutLike.com</li>
                                                            <li>ns2.ToutLike.com</li>
                                                    </ul>
                    </div>
                </div>
                <div class="form-group">
                    <label class="control-label"
                          for="createorderform-currency">Devise</label>
                    <select class="form-control" name="panel_currency" required>
{{ child_panel_currencies }}
</select>
                </div>
                <div class="form-group">
                    <label class="control-label"
                          for="createorderform-username">Nom dutilisateur admin</label>
                    <input
                            type="text" id="createorderform-username" class="form-control"
                            name="admin_username" aria-required="true"
                            value="">
                </div>
                <div class="form-group">
                    <label class="control-label"
                          for="createorderform-password">Mot de passe admin</label>
                    <input
                            type="password" id="createorderform-password" class="form-control"
                            name="admin_password" aria-required="true">
                </div>
                <div class="form-group">
                    <label class="control-label"
                          for="createorderform-password_confirm">Confirmer le mot de passe</label>
                    <input
                            type="password" id="createorderform-password_confirm" class="form-control"
                            name="admin_confirm_password" aria-required="true">
                </div>
                <div class="form-group">
                    <label for="price" class="control-label">Prix par mois</label>
                    <input type="text" class="form-control" id="price" value="{{site_base_currency_symbol}}{{" "}}{{site["childpanel_price"]}}" readonly>
                </div>
                <button type="submit" class="btn btn-primary w-100">Soumettre la commande</button>
            </form>
                    </div>
        </div>
      </div>
      <div class="col-lg-6 col-md-6 col-12">
        <div class="card card_auth_1 mb-3">
          <div class="card-header d-flex flex-column justify-content-center">
            <h3>FAQ Panel enfant</h3>
            <p>Lisez avant de commander un panel enfant.</p>
          </div>
          <div class="card-body">
            <div class="faq_accordion">
              <div class="accordion" id="accordionExample">
                <div class="accordion-item">
                  <h2 class="accordion-header">
                    <button
                      class="accordion-button collapsed"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#collapseOne"
                      aria-expanded="true"
                      aria-controls="collapseOne"
                    >
                    Quest-ce quun panel enfant ?
                    </button>
                  </h2>
                  <div
                    id="collapseOne"
                    class="accordion-collapse collapse"
                    data-bs-parent="#accordionExample"
                  >
                    <div class="accordion-body">
                      <p>
                        A child panel is a panel with a limited selection of features that is linked to one of your regular panels such as ToutLike.com
                      </p>
                    </div>
                  </div>
                </div>
                <div class="accordion-item">
                  <h2 class="accordion-header">
                    <button
                      class="accordion-button collapsed"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#collapseTwo"
                      aria-expanded="false"
                      aria-controls="collapseTwo"
                    >
                    Combien coute un panel enfant ?
                    </button>
                  </h2>
                  <div
                    id="collapseTwo"
                    class="accordion-collapse collapse"
                    data-bs-parent="#accordionExample"
                  >
                    <div class="accordion-body">
                      <p>
                        It will cost you $10.00 per month. Please note, you paying for panel, not for services, you have to pay for the services you will purchase from ToutLike
                      </p>
                    </div>
                  </div>
                </div>
                <div class="accordion-item">
                  <h2 class="accordion-header">
                    <button
                      class="accordion-button collapsed"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#collapseThree"
                      aria-expanded="false"
                      aria-controls="collapseThree"
                    >
                    Combien de temps faut-il pour activer the child panel ?
                    </button>
                  </h2>
                  <div
                    id="collapseThree"
                    class="accordion-collapse collapse"
                    data-bs-parent="#accordionExample"
                  >
                    <div class="accordion-body">
                      <p>
                        It will take 3-6 hrs to active your child panel if you changed your name server perfectly.
                      </p>
                    </div>
                  </div>
                </div>
                <div class="accordion-item">
                  <h2 class="accordion-header">
                    <button
                      class="accordion-button collapsed"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#collapseFour"
                      aria-expanded="false"
                      aria-controls="collapseFour"
                    >
                    Avez-vous besoin dun hebergement pour le panel enfant ?
                    </button>
                  </h2>
                  <div
                    id="collapseFour"
                    class="accordion-collapse collapse"
                    data-bs-parent="#accordionExample"
                  >
                    <div class="accordion-body">
                      <p>
                        No, for child panel you just need a domain and that's all.
                      </p>
                    </div>
                  </div>
                </div>
                <div class="accordion-item">
                  <h2 class="accordion-header">
                    <button
                      class="accordion-button collapsed"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#collapseFive"
                      aria-expanded="false"
                      aria-controls="collapseFive"
                    >
                    Ji un domaine, que puis-je faire ensuite ?
                    </button>
                  </h2>
                  <div
                    id="collapseFive"
                    class="accordion-collapse collapse"
                    data-bs-parent="#accordionExample"
                  >
                    <div class="accordion-body">
                      <p>
                        If you have domain, you can simply change your domain name server and point it to
                        ns1.perfectdns.com ns2.perfectdns.com
                        After you successfully changed the name server, you can submit a order for child panel.
                      </p>
                    </div>
                  </div>
                </div>
                <div class="accordion-item">
                  <h2 class="accordion-header">
                    <button
                      class="accordion-button collapsed"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#collapseSix"
                      aria-expanded="false"
                      aria-controls="collapseSix"
                    >
                    Comment changer les serveurs de noms de mon domaine ?
                    </button>
                  </h2>
                  <div
                    id="collapseSix"
                    class="accordion-collapse collapse"
                    data-bs-parent="#accordionExample"
                  >
                    <div class="accordion-body">
                      <p>
                        Its actually depend on your domain provider, if you go to your domain settings and choose custom DNS and enter the name server given by ToutLike.
                      </p>
                    </div>
                  </div>
                </div>
                <div class="accordion-item">
                  <h2 class="accordion-header">
                    <button
                      class="accordion-button collapsed"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#collapseSeven"
                      aria-expanded="false"
                      aria-controls="collapseSeven"
                    >
                    Comment connecter le panel enfant avec ToutLike ?
                    </button>
                  </h2>
                  <div
                    id="collapseSeven"
                    class="accordion-collapse collapse"
                    data-bs-parent="#accordionExample"
                  >
                    <div class="accordion-body">
                      <p>
                        You can simply go to https://yourdomain.com/admin/settings/providers and you will find out option to connect your panel with ToutLike. You can a key to connect your panel with ToutLike. This key you will find out on settings of your ToutLike account.
                      </p>
                    </div>
                  </div>
                </div>
                <div class="accordion-item">
                  <h2 class="accordion-header">
                    <button
                      class="accordion-button collapsed"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#collapseEight"
                      aria-expanded="false"
                      aria-controls="collapseEight"
                    >
                    Comment puis-je obtenir un remboursement pour le panel enfant if i am not interested to continue?
                    </button>
                  </h2>
                  <div
                    id="collapseEight"
                    class="accordion-collapse collapse"
                    data-bs-parent="#accordionExample"
                  >
                    <div class="accordion-body">
                      <p>
                        Unfortunately refund not possible after we activate your child panel. But you can terminate your child panel any time by creating a ticket to us.
                      </p>
                    </div>
                  </div>
                </div>
                <div class="accordion-item">
                  <h2 class="accordion-header">
                    <button
                      class="accordion-button collapsed"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#collapseNine"
                      aria-expanded="false"
                      aria-controls="collapseNine"
                    >
                    Je veux changer ldresse de domaine de mon panel enfant, what i need to do ?
                    </button>
                  </h2>
                  <div
                    id="collapseNine"
                    class="accordion-collapse collapse"
                    data-bs-parent="#accordionExample"
                  >
                    <div class="accordion-body">
                      <p>
                        You can simply, change your new domain name server and send to us your new domain address. We will replace your new domain with old domain. But, this change only possible for 1 time.
                      </p>
                    </div>
                  </div>
                </div>
                <div class="accordion-item">
                  <h2 class="accordion-header">
                    <button
                      class="accordion-button collapsed"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#collapseTen"
                      aria-expanded="false"
                      aria-controls="collapseTen"
                    >
                    Comment ajouter une passerelle de paiement sur mon panel enfant ?
                    </button>
                  </h2>
                  <div
                    id="collapseTen"
                    class="accordion-collapse collapse"
                    data-bs-parent="#accordionExample"
                  >
                    <div class="accordion-body">
                      <p>
                        You can visit https://yourdomain.com/admin/settings/payments - Add method - Choose Payment Method
                      </p>
                    </div>
                  </div>
                </div>
                <div class="accordion-item">
                  <h2 class="accordion-header">
                    <button
                      class="accordion-button collapsed"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#collapseEleven"
                      aria-expanded="false"
                      aria-controls="collapseEleven"
                    >
                    Comment collecter lrgent de mes clients ?
                    </button>
                  </h2>
                  <div
                    id="collapseEleven"
                    class="accordion-collapse collapse"
                    data-bs-parent="#accordionExample"
                  >
                    <div class="accordion-body">
                      <p>
                        You customer will pay to your own payment gateway account, they are not paying to us. So, you don't have to worry about payment. Setup your own payment gateway, and collect payment from your customers.
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

        </main>

            </div>
      </section>
      </div></div>
     <div class="">
              <div class="table-responsive custom-table">
            <table class="table ">
              <thead>
            <tr>
              <th>#</th>
              <th>Domaine</th>
              <th>Devise</th>
              <th class="width-40">Username</th>
              <th>Mot de passe</th>
              <th class="nowrap">Date</th>
              <th class="nowrap">Status</th>
            </tr>
          </thead>
         <tbody>

{% for logs in chilpanel_logs %}
<tr>
<td>{{ logs['id'] }}</td>
<td>{{ logs['domain'] }}</td>
<td>{{ logs['child_panel_currency'] }}</td>
<td class="nowrap">{{ logs['created_on'] }}</td>
<td class="nowrap">
{{ logs["child_panel_status"] }}
</td>
<td>{{logs["renewal_date"] }}</td>
</tr>
{% endfor %}
</tbody>
        </table>
      </div>
    <div class="response_msg"></div>
    </div></div></div></div>
    <script src="http://ajax.googleapis.com/ajax/libs/jquery/1.11.2/jquery.min.js"></script>
   </div></div>
</div>
{% include 'footer.twig' %}
