{% extends 'public_base.twig' %}
{% block title %}R&eacute;initialiser le mot de passe - {{ site['site_name'] }}{% endblock %}
{% block content %}
<div class="container" style="max-width:440px">
  <div class="page-header anim">
    <h1>Mot de passe oubli&eacute; ?</h1>
    <p>Entrez votre nom d'utilisateur ou e-mail et nous vous enverrons un lien de r&eacute;initialisation.</p>
  </div>
  <div class="card anim">
    {% if error %}<div class="alert alert-d">{{ errorText }}</div>{% endif %}
    {% if success %}<div class="alert alert-s">{{ successText }}</div>{% endif %}
    <form method="post" action="/resetpassword">
      {{ csrf_field() }}
      <div class="fg">
        <label for="user">Nom d'utilisateur ou e-mail</label>
        <input type="text" id="user" name="user" placeholder="Votre identifiant ou e-mail" required autofocus>
      </div>
      {% if captcha %}
        <div class="fg">
          <div class="g-recaptcha" data-sitekey="{{ captchaKey }}"></div>
          <script src="https://www.google.com/recaptcha/api.js" async defer></script>
        </div>
      {% endif %}
      <button type="submit" class="btn btn-full">Envoyer le lien</button>
    </form>
    <div style="text-align:center;margin-top:16px;font-size:13px;color:var(--muted)">
      <a href="/">Retour &agrave; la connexion</a>
    </div>
  </div>
</div>
{% endblock %}
