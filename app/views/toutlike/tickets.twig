{% include 'header.twig' %}


{% if settings['ticket_system'] == 1 %}
<!-- Ticket Chat Page --><!-- Main variables *content* -->
        <main class="auth">
                    <div class="about_us_effect">
            <img
              src="https://cdn.smmpanelbdlab.com/work/PerfectPanel/img/bg-img1.png"
              class="img-fluid about_us_img_left"
              alt=""
            />
            <img
              src="https://cdn.smmpanelbdlab.com/work/PerfectPanel/img/bg-img2.png"
              class="img-fluid about_us_img_right"
              alt=""
            />
          </div>
<!-- Ticket Page -->
<section id="auth_banner">
  <div class="container-fluid">
    <div class="row d-flex align-items-center">
      <div class="col-lg-6 col-md-6 col-12">
        <div class="banner_content">
          <h2>Ticket de support</h2>
          <p>
          Creez un ticket de support en selectionnant le bon sujet, vous obtiendrez des solutions pour votre commande depuis l'equipe de support. Veuillez vous assurer de bien decrire votre probleme. Restez avec nous, nous faisons toujours de notre mieux pour vos services.
          </p>
        </div>
      </div>
      <div class="col-lg-6 col-md-6 col-12">
        <div class="banner_image">
          <img
            src="https://cdn.smmpanelbdlab.com/smmscript/smmrx/img/support-ticket-right-image.png"
            class="img-fluid"
            alt=""
          />
        </div>
      </div>
    </div>
  </div>
</section>

<section id="ticketPage">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-6 col-md-6 col-12">
                <div class="card card_auth_1 mb-3">
                    <div class="card-header d-flex flex-column justify-content-center">
                        <h3>Creer un ticket</h3>
                        <p>
                            Vous pouvez creer un ticket de support ici.
                        </p>
                    </div>
                    {% if error %}
        <div class="alert alert-dismissible alert-danger">
          <button type="button" class="close" data-dismiss="alert">×</button>
          {{ errorText }}
        </div>
      {% endif %}
      {% if success %}
        <div class="alert alert-dismissible alert-success">
          <button type="button" class="close" data-dismiss="alert">×</button>
          {{ successText }}
        </div>
      {% endif %}

                    <div class="card-body">
                      <form method="post" action="tickets">
                {{ csrf_field() }}
                        <div class="alert alert-dismissible alert-danger ticket-danger " style="display: none">
                          <button type="button" class="close">&times;</button>
                          <div></div>
                        </div>
            
                                              <div class="form-group">
                          <label for="subject" class="control-label">{{ lang['tickets.subject'] }}</label>
                          <select  type="text" class="form-control" id="subject" name="subject">
                                  {% for subjects in orders %}
                   <option value"{{ subjects['subject'] }}">{{ subjects['subject'] }}</option>
                  {% endfor %}
                              </select>
                        </div>
                                  
                      <div class="form-group">
                        <label for="message" class="control-label">{{ lang['tickets.message'] }}</label>
                        <textarea class="form-control" rows="7" id="message" name="message">{{ data['message'] }}</textarea>
                      </div></br>
                      <button type="submit" class="btn btn-primary w-100">Submit ticket</button>
                    </form>
                    </div>
                </div>
            </div>
        <div class="col-lg-6 col-md-6 col-12">
              <div class="card card_auth_1 mb-3">
                  <div class="card-header d-flex flex-column justify-content-center">
                      <h3>Ticket History</h3>
                      <p>
                          See your support ticket history here.
                      </p>
                  </div>
                  <div class="card-body">
                                            <form action="/tickets" method="get" id="history-search">
                {{ csrf_field() }}
                                                 <div class="search_inputs ">
                          <div class="search">
                                                    <input type="text" name="search" class="search_input" value="" placeholder="Search tickets">
                                                    <div class="input-group-append component_button_search">
                                                        <button class="icon" type="submit">
                                                            <span class="fas fa-search"></span>
                                                        </button>
                                                   </div>
                      </div>
                  </form>
                    <br>
                      <div class="ticket_history">
                           {% for ticket in ticketList %}
                           
                    <a href="tickets/{{ ticket['ticket_id'] }}">
                                      <div class="tickets_his_item ">
                                          <div class="tickets_his_id">
                                              <h5>{{ ticket['ticket_id'] }}</h5>
                                          </div>
                                          <div class="tickets_his_sub">
                                                                                            <h5>{{ ticket['subject'] }}</h5>
                                                                                        </div>
                                          <div class="tickets_his_status">
                                              <h5 class="ticket_Responded">{{ ticket['status'] }}</h5>
                                          </div>
                                          <div class="tickets_his_lastUpdate">
                                              <h5>{{ ticket['lastupdate_time'] }}</h5>
                                          </div>
                                      </div>
                                  </a>{% endfor %}
                                                
                                                                                  <div class="my-3">
                                                        </div>
                      </div>

                      <div class="d-flex justify-content-center">
                                              </div>

                  </div>
              </div>
            </div>
        </div>
    </div>
</section>

<!-- ### Ticket Page -->

        </main>

            </div>
      </section>
      {% endif %}
<div id="block_81">
    <div class="tickets-list">
        <div class="bg"></div>
        <div class="divider-top"></div>
        <div class="divider-bottom"></div>
        <div class="container">
            <div class="row tickets-list__alignment">
                
</div></div></div>
</div></div>
</div></div>
{% if pagination["count"] > 1 %}
        <ul class="pagination">

          {% if pagination["current"] != 1 %}
            <li>
              <a href="tickets/{{ id }}/{{ pagination["previous"] }}{% if search %}?search={{ search }}{% endif %}" aria-label="Previous">
                <span aria-hidden="true">«</span>
              </a>
            </li>
          {% endif %}

          {% set r, l = 3, 3 %}

          {% if pagination['current'] == 1 %}
            {% set r = 7 %}
          {% endif %}

          {% if pagination['current'] == 2 %}
            {% set r = 5 %}
          {% endif %}

          {% if pagination['current'] >= pagination['count'] %}
            {% set l = 5 %}
          {% endif %}

          {% for page in 1..pagination["count"] %}
            {% if page >= (pagination['current']-l) and page <= (pagination['current']+r) %}
              <li{% if page == pagination['current'] %} class="active" {%endif%}><a href="tickets/{{ id }}/{{ page }}{% if search %}?search={{ search }}{% endif %}">{{ page }}</a></li>
            {%endif%}
          {% endfor %}

          {% if pagination['current'] < pagination['count'] %}
            <li>
              <a href="ticket/{{ id }}/{{ pagination['next'] }}{% if search %}?search={{ search }}{% endif %}" aria-label="Next">
                <span aria-hidden="true">»</span>
              </a>
            </li>
          {% endif %}

        </ul>
      {% endif %}

    
  
 
