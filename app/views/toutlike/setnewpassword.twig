{% extends 'public_base.twig' %}
{% block title %}Nouveau mot de passe - {{ site['site_name'] }}{% endblock %}
{% block content %}
<div class="container" style="max-width:440px">
  <div class="page-header anim">
    <h1>Nouveau mot de passe</h1>
    <p>Choisissez un nouveau mot de passe pour votre compte.</p>
  </div>
  <div class="card anim">
    {% if error %}<div class="alert alert-d">{{ errorText }}</div>{% endif %}
    {% if success %}<div class="alert alert-s">{{ successText }}</div>{% endif %}
    <form method="post">
      {{ csrf_field() }}
      <div class="fg">
        <label for="password">Nouveau mot de passe</label>
        <input type="password" id="password" name="password" placeholder="8 caract&egrave;res minimum" required>
      </div>
      <div class="fg">
        <label for="password_again">Confirmer le mot de passe</label>
        <input type="password" id="password_again" name="password_again" placeholder="Retapez le mot de passe" required>
      </div>
      <button type="submit" class="btn btn-full">Changer le mot de passe</button>
    </form>
  </div>
</div>
{% endblock %}
