
{% include 'header.twig' %}





<div class="wrapper-content">
    <div class="wrapper-content__header">
          </div>
    <div class="wrapper-content__body">
      <!-- Main variables *content* -->
      <div id="block_16" class="container-fluid col-lg-12" style=" margin:0 auto;">
    <div class="addfunds-block ">
        <div class="bg"></div>
        <div class="divider-top"></div>
        <div class="divider-bottom"></div>
        <div class="container">
            <div class="row addfunds-form">
                <div class="col-lg-12">
                   <div class="component_form_group component_card component_radio_button">
                     

				<br>

				{% if error %}
					<div class="alert alert-dismissible alert-danger">
						{{ errorText }}
					</div>
					<br>
				{% endif %}

				{% if success %}
					<div class="alert alert-dismissible alert-success">
						{{ successText }}
					</div>
					<br>
				{% endif %}

                        
<div class="row affiliates-info__alignment">
                <div class="col-lg-12">
                    <div class="table-bg component_table_statistics ">
                        <div class="table-wr table-responsive">
                            <table class="table">
                                <thead>
                                <tr>

                                    <th>Lien de parrainage</th>
                                    <th>Taux de commission</th>
                                    <th>Seuil de paiement</th>
                                </tr>
                                </thead>
                                <tbody>
                                <tr class="affiliates-table-border-none">
<tr>
                                    <td data-label="Lien de parrainage" nowrap>
                                        <span id="link-1" class="mr-1">{{ site["url"] }}/affiliates?ref={{ user['ref_code'] }}</span>
                                        <a>
                                            <span
                                                data-clip="true"
                                                title="Lien copie"
                                                data-clipboard-action="copy"
                                                data-clipboard-target="#link-1"
                                                class="fas fa-clone"></span>
                                        </a>
                                    </td>
                                    <td data-label="Taux de commission">{{settings["referral_commision"]}}%</td>
                                    <td data-label="Seuil de paiement">{{ settings["referral_payout"] }}</td>
                                </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
<br>
            <div class="row affiliates-info__alignment">
                <div class="col-lg-12">
                    <div class="table-bg component_table_statistics ">
                        <div class="table-wr table-responsive">
                            <table class="table">
                                <thead>
                                <tr>
                                    <th>Visites totales</th>
                                    <th>Parrainages reussis</th>
                                    <th>Taux de conversion</th>
                                    <th>Gains totaux</th>
<th>Gains payes</th>
                                    <th>Gains disponibles</th>
                    <th>Gains refuses</th>

<th>Action</th>
                                </tr>
                                </thead>
                                <tbody>
                                <tr class="affiliates-table-border-none">
<tr>
                                   

	{% for ref in ref_content %}																
<td>{{ ref['referral_clicks'] }}</td>
<td>{{ ref['referral_sign_up'] }}</td>
<td>
    {% if ref["referral_clicks"] %}
 {{ ( ref['referral_sign_up'] / ref['referral_clicks']) * 100 }}%</td>
  {% else %}
  {{ "NaN" }}%
  {% endif %}
<td>
    {{ ref['referral_total_commision']}}
</td>

<td>{{ ref['referral_earned_commision'] }}</td>

<td>{{ (ref['referral_total_commision'] - (ref['referral_earned_commision']  +  ref['referral_requested_commision'] +  ref['referral_rejected_commision'])) }}</td>


<td>{{ ref['referral_rejected_commision'] }}</td>
<td><form method="post" action="">
                {{ csrf_field() }}

																				<input type="hidden" name="ref_code" value="{{ user['ref_code'] }}">
																				<input type="hidden" name="ref_amt" value="{{ ref['referral_total_commision'] - (ref['referral_earned_commision'] + ref['referral_requested_commision'] ) }}">
																				<a href="javascript:void(0)">
																				{% if (ref['referral_total_commision'] - (ref['referral_earned_commision'] + ref['referral_requested_commision'] + ref['referral_rejected_commision'] )) >= settings["referral_payout"] %} <button type="submit" style="margin-left:2px;" class="btn btn-actions">Demander le paiement</button>
															 {% endif %} 						</a>

																			</form>
																		</td>
																	</tr>
																</td>
															</tbody>
													
													{% endfor %}
	</tr>

												</tbody> 
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div></div>
<br>
<div id="block_14">
    <div class="affiliates-list">
        <div class="bg"></div>
        <div class="divider-top"></div>
        <div class="divider-bottom"></div>
        <div class="container-fluid">
            <div class="row affiliate-list__alignment">
                <div class="col-lg-12">
                    <div class="table-bg affiliate-block__table-payments component_table ">
                        <div class="table-wr table-responsive">
                            <table class="table">
                                <thead>
                                <tr>
                                    <th>Date de paiement</th>
                                    <th>Montant du paiement</th>
<th>Derniere mise a jour</th>
                                    <th>Statut du paiement</th>
                                </tr>
                                </thead>
                                <tbody>
	{% for ref_payout in ref_payouts %}
														<tr>
<td>{{ ref_payout['r_p_requested_at'] }}</td>
<td>{{ currency['symbol'] }}{{ ref_payout['r_p_amount_requested'] }}</td>
<td>{{ ref_payout['r_p_updated_at'] }}</td>
<td>
																{% if (ref_payout['r_p_status'] == 0)  %}
																	{{ "En attente" }}
																{% elseif (ref_payout['r_p_status'] == 1)  %}
																	{{ "Refuse" }}
																{% elseif (ref_payout['r_p_status'] == 2)  %}
																	{{ "Approuve" }}
																{% elseif (ref_payout['r_p_status'] == 3)  %}
																	{{ "Rejete" }}
																{% endif %}
															</td>

														</tr>
													{% endfor %}
												</tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row affiliate-list__alignment">
                <div class="col-lg-12">
                    <nav class="component_pagination">
                        <div class="">
                                                    </div>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>
</div></div>
</div>
{% include 'footer.twig' %}


