			<script>
var paymentMethods = {{ site["paymentMethodsJSON"]|raw }};
			</script>
			<script>
				const addfundsRoute = "/addfunds";
function addfundsInit() {
var fields = $("#addfunds_fields");
var selectedMethod = $("#payment_method").val();
var instructions = paymentMethods[selectedMethod] ? paymentMethods[selectedMethod][0].instructions : "";
$.ajax({
url: addfundsRoute,
data: "action=getForm&selectedMethod=" + selectedMethod + "&_csrf_token={{ csrf_token() }}",
type: "POST",
success: function (json) {
if (json.success == true) {
if (instructions.length > 0) {
var methodInstruction = '<div class="form-group"><label class="control-label">Instructions de paiement</label><div class="panel-body border-solid border-rounded">' + instructions + '</div></div>';
} else {
var methodInstruction = "";
} fields.html(methodInstruction + json.content);
extraFeeInit(selectedMethod);
}
}
});
}

function extraFeeInit(method) {
var fields = $("#fee_fields");
var methodData = paymentMethods[method] ? paymentMethods[method][0] : null;
var fee = methodData ? parseFloat(methodData.fee || 0) : 0;
if (fee > 0) {
fields.html('<div class="om-fee-grid"><div class="form-group om-fee-card"><label class="control-label">Frais Orange Money (' + fee.toFixed(2) + '%)</label><input type="text" class="form-control" id="methodExtraFee" disabled value="0" /></div><div class="form-group om-fee-card"><label class="control-label">Total à payer (GNF)</label><input type="text" id="totalAmount" class="form-control" disabled value="0" /></div></div>');
} else {
fields.html("");
}
}
function preparePrice(t) {
n = 2;
var r = (t = $.trim(t.toString().replace(",", "."))).split(".");
return void 0 !== r[1] && (r[1] = r[1].replace(/0+$/g, ""), r[1].length > n && (n = 2 < r[1].length ? 2 : r[1].length)),
1e3 <= (t =( t = parseFloat(t)).toFixed(n)) && (t = t.toString().replace(/(\d)(?=(\d\d\d)+([^\d]|$))/g, "$1" + "")),
t = t.toString().replace(/\.(\d+)$/g, "." + "$1");
return t.toFixed(n)
}
function formatGNFAmount(amount) {
amount = Math.round(parseFloat(amount) || 0);
return amount.toString().replace(/\B(?=(\d{3})+(?!\d))/g, " ");
}
function setAmount(val) {
  var input = document.getElementById('paymentAmount');
  if (input) {
    input.value = val;
    if (window.jQuery) {
      $(input).trigger("input").trigger("keyup");
    } else {
      input.dispatchEvent(new Event('input', { bubbles: true }));
    }
  }
}
$(document).ready(function () {
if (paymentMethods[21]) {
$("#payment_method").val("21");
}
$(document).on("input keyup", "#paymentAmount", function () {
var selectedMethod = $("#payment_method").val();
var amount = parseFloat($(this).val());
if (isNaN(amount) || amount < 0) {
amount = 0;
}
var feePercentage = paymentMethods[selectedMethod] ? parseFloat(paymentMethods[selectedMethod][0].fee || 0) : 0;
var feeInput = $("#methodExtraFee");
var totalAmountInput = $("#totalAmount");
var fee = amount * (feePercentage / 100);
feeInput.val(formatGNFAmount(fee));
totalAmountInput.val(formatGNFAmount(amount + fee));
});
addfundsInit();
});
$("#payment_method").change(function () {
addfundsInit();
});

$("#addfundsForm").submit(function (e) {
e.preventDefault();
var data = $(this).serialize();

$.ajax({
url: addfundsRoute,
data: data,
type: "POST",
success: function (json) {
if (json.success == true) {
var msgDiv = $("#formSubmitResponseMessage");
msgDiv.html('<div class="alert alert-success alert-dismissible fade show mt-2" role="alert">' + json.message + '<button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">×</span></button></div>');
var contentDiv = $("#formSubmitResponseContent");
contentDiv.html(json.content);
} else {
var msgDiv = $("#formSubmitResponseMessage");
msgDiv.html('<div class="alert alert-danger alert-dismissible fade show mt-2" role="alert">' + json.message + '<button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">×</span></button></div>');
}
}

});
});
			</script>
