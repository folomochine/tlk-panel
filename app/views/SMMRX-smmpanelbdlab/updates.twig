{% include 'header.twig' %}

<style>
/* Badges action colorés */
.tl-up-badge{
  display:inline-flex;align-items:center;gap:5px;padding:5px 10px;border-radius:4px;
  font-size:12px;font-weight:700;line-height:1;white-space:nowrap;
}
.tl-up-badge i{font-size:11px}
.tl-up-badge.up{background:#f8d7da;color:#842029}
.tl-up-badge.down{background:#d1e7dd;color:#0f5132}
.tl-up-badge.on{background:#cfe2ff;color:#084298}
.tl-up-badge.off{background:#e2e3e5;color:#41464b}
.tl-up-badge.neutral{background:#fff3cd;color:#664d03}
</style>

<div class="wrapper-content">
    <div class="wrapper-content__header">
          </div>

    <div class="wrapper-content__body">
      <!-- Main variables *content* -->
      <div id="block_99">
    <div class="orders-history ">
        <div class="bg"></div>
        <div class="divider-top"></div>
        <div class="divider-bottom"></div>
        <div class="container-fluid">
            <div class="row">
                <div class="col">
                    <div class="orders-history__margin-tab">
                        <div class="component_status_tabs">
                            <div class="">
      <ul class="nav nav-pills tab ">
	  
        <li class="nav-item" >
		
      </ul><br>
	
     <div class="row">
                <div class="col">
                    <div class="orders-history__margin-table">
                        <div class="table-bg component_table ">
                            <div class="table-wr table-responsive">
        <table class="table ">
          <thead>
            <tr>
<th class="width-service-name"><span>ID</span></th>
<th width="40%">Nom du service</th>
              <th width="20%">Description</th>
<th><i class="fa fa-clock" style="margin-right:4px"></i> Date</th>
              <th><i class="fa fa-bolt" style="margin-right:4px"></i> Action</th>
            </tr>
          </thead>
          <tbody>

            {% for order in orders %}
              {% set act = order['action'] %}
              {% set actLabel = act %}
              {% set actClass = 'neutral' %}
              {% set actIcon = 'fa-bolt' %}
              {% if act == 'Price Increased' %}{% set actLabel = 'Prix augmenté' %}{% set actClass = 'up' %}{% set actIcon = 'fa-arrow-up' %}
              {% elseif act == 'Price Decreased' %}{% set actLabel = 'Prix diminué' %}{% set actClass = 'down' %}{% set actIcon = 'fa-arrow-down' %}
              {% elseif act == 'Minimum Increased' %}{% set actLabel = 'Minimum augmenté' %}{% set actClass = 'up' %}{% set actIcon = 'fa-angle-double-up' %}
              {% elseif act == 'Minimum Decreased' %}{% set actLabel = 'Minimum diminué' %}{% set actClass = 'down' %}{% set actIcon = 'fa-angle-double-down' %}
              {% elseif act == 'Maximum Increased' %}{% set actLabel = 'Maximum augmenté' %}{% set actClass = 'up' %}{% set actIcon = 'fa-angle-double-up' %}
              {% elseif act == 'Maximum Decreased' %}{% set actLabel = 'Maximum diminué' %}{% set actClass = 'down' %}{% set actIcon = 'fa-angle-double-down' %}
              {% elseif act == 'Refill Activated' %}{% set actLabel = 'Remplissage activé' %}{% set actClass = 'on' %}{% set actIcon = 'fa-sync-alt' %}
              {% elseif act == 'Refill Deactivated' %}{% set actLabel = 'Remplissage désactivé' %}{% set actClass = 'off' %}{% set actIcon = 'fa-sync-alt' %}
              {% elseif act == 'Cancel Activated' %}{% set actLabel = 'Annulation activée' %}{% set actClass = 'on' %}{% set actIcon = 'fa-ban' %}
              {% elseif act == 'Cancel Deactivated' %}{% set actLabel = 'Annulation désactivée' %}{% set actClass = 'off' %}{% set actIcon = 'fa-ban' %}
              {% endif %}

              {% set desc = order['description'] %}
              {% set descFr = desc %}
              {% if desc starts with 'Price changed from' %}{% set descFr = desc|replace({'Price changed from':'Prix modifié : de',' to ':' → '}) %}
              {% elseif desc starts with 'Minimum amount changed from' %}{% set descFr = desc|replace({'Minimum amount changed from':'Minimum modifié : de',' to ':' → '}) %}
              {% elseif desc starts with 'Maximum amount changed from' %}{% set descFr = desc|replace({'Maximum amount changed from':'Maximum modifié : de',' to ':' → '}) %}
              {% elseif desc == 'Refill Button has been activated' %}{% set descFr = 'Le bouton Remplissage a été activé.' %}
              {% elseif desc == 'Refill Button has been Deativated' or desc == 'Refill Button has been Deactivated' %}{% set descFr = 'Le bouton Remplissage a été désactivé.' %}
              {% elseif desc == 'Cancel Button has been activated' %}{% set descFr = 'Le bouton Annulation a été activé.' %}
              {% elseif desc == 'Cancel Button has been Deativated' or desc == 'Cancel Button has been Deactivated' %}{% set descFr = 'Le bouton Annulation a été désactivé.' %}
              {% endif %}

              <tr>
<td>{{ order['service_id'] }}</td>
                <td>{{ order['service_name'] }}</td>
                 <td>{{ descFr }}</td>
      <td><i class="fa fa-clock" style="margin-right:4px;opacity:.6"></i>{{ order['date'] }}</td>
          <td><span class="tl-up-badge {{ actClass }}"><i class="fa {{ actIcon }}"></i> {{ actLabel }}</span></td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    <br>
     {% if pagination["count"] > 1 %}
        <ul class="pagination">

          {% if pagination["current"] != 1 %}
            <li>
              <a class="btn btn-actions" href="updates/{{ status }}/{{ pagination["previous"] }}{% if search %}?search={{ search }}{% endif %}" aria-label="Précédent">
                <span aria-hidden="true">«</span>
              </a>
            </li>
          {% endif %}

          {% set r, l = 3, 3 %}

          {% if pagination['current'] == 1 %}
            {% set r = 7 %}
          {% endif %}

          {% if pagination['current'] == 2 %}
            {% set r = 5 %}
          {% endif %}

          {% if pagination['current'] >= pagination['count'] %}
            {% set l = 5 %}
          {% endif %}

          {% for page in 1..pagination["count"] %}
            {% if page >= (pagination['current']-l) and page <= (pagination['current']+r) %}
              <li{% if page == pagination['current'] %} class="active" {%endif%}><a class="btn btn-actions" 
 href="updates/{{ status }}/{{ page }}{% if search %}?search={{ search }}{% endif %}">{{ page }}</a></li>
            {%endif%}
          {% endfor %}

          {% if pagination['current'] < pagination['count'] %}
            <li>
              <a class="btn btn-actions" href="updates/{{ status }}/{{ pagination['next'] }}{% if search %}?search={{ search }}{% endif %}" aria-label="Suivant">
                <span aria-hidden="true">»</span>
              </a>
            </li>
          {% endif %}

        </ul>
      {% endif %}


    </div>
  </div>
</div></div></div></div>
</div></div></div></div></div></div>
</div>




<br><br><br><br><br>
{% include 'footer.twig' %}
