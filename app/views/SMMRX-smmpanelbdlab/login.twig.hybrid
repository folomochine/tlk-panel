{% include 'header.twig' %}
<!-- Main variables *content* -->
<style>
/* === TOUTLIKE MODERN LOGIN PAGE === */

/* Animated gradient background for banner */
#banner {
  position: relative;
  overflow: hidden;
  background: linear-gradient(-45deg, #0a0e27, #1a1a3e, #0d2137, #0a1628);
  background-size: 400% 400%;
  animation: gradientShift 12s ease infinite;
}
@keyframes gradientShift {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

/* Floating particles */
#banner::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background-image:
    radial-gradient(2px 2px at 20% 30%, rgba(255,255,255,0.15), transparent),
    radial-gradient(2px 2px at 40% 70%, rgba(255,255,255,0.1), transparent),
    radial-gradient(1px 1px at 60% 20%, rgba(255,255,255,0.12), transparent),
    radial-gradient(1px 1px at 80% 50%, rgba(255,255,255,0.08), transparent),
    radial-gradient(2px 2px at 10% 80%, rgba(255,255,255,0.1), transparent),
    radial-gradient(1px 1px at 90% 10%, rgba(255,255,255,0.12), transparent),
    radial-gradient(2px 2px at 50% 50%, rgba(255,255,255,0.06), transparent),
    radial-gradient(1px 1px at 30% 90%, rgba(255,255,255,0.1), transparent),
    radial-gradient(1px 1px at 70% 40%, rgba(255,255,255,0.08), transparent),
    radial-gradient(2px 2px at 15% 55%, rgba(255,255,255,0.07), transparent);
  animation: particlesFloat 20s linear infinite;
  pointer-events: none;
  z-index: 1;
}
@keyframes particlesFloat {
  0% { transform: translateY(0); }
  100% { transform: translateY(-50px); }
}

/* Glassmorphism login card */
.banner_login_part {
  background: rgba(255, 255, 255, 0.05) !important;
  backdrop-filter: blur(20px) !important;
  -webkit-backdrop-filter: blur(20px) !important;
  border: 1px solid rgba(255, 255, 255, 0.1) !important;
  border-radius: 24px !important;
  padding: 40px 30px !important;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3), inset 0 1px 0 rgba(255,255,255,0.1) !important;
  transition: transform 0.4s ease, box-shadow 0.4s ease !important;
}
.banner_login_part:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255,255,255,0.15) !important;
}
.banner_login_part h4 {
  background: linear-gradient(135deg, #fff, #a8c0ff);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 700;
  font-size: 1.4rem;
}

/* Modern inputs */
.banner_login_part .form-control {
  background: rgba(255, 255, 255, 0.06) !important;
  border: 1px solid rgba(255, 255, 255, 0.12) !important;
  border-radius: 14px !important;
  color: #fff !important;
  padding: 14px 16px 14px 50px !important;
  font-size: 14px !important;
  transition: all 0.3s ease !important;
}
.banner_login_part .form-control::placeholder {
  color: rgba(255, 255, 255, 0.45) !important;
}
.banner_login_part .form-control:focus {
  background: rgba(255, 255, 255, 0.1) !important;
  border-color: rgba(100, 180, 255, 0.5) !important;
  box-shadow: 0 0 0 3px rgba(100, 180, 255, 0.15), 0 0 20px rgba(100, 180, 255, 0.1) !important;
  outline: none !important;
}

/* Input icons */
.banner_login_part .form-group.has_icon .icon {
  position: absolute;
  left: 16px;
  top: 50%;
  transform: translateY(-50%);
  z-index: 2;
  opacity: 0.5;
  transition: opacity 0.3s ease;
}
.banner_login_part .form-group.has_icon:focus-within .icon {
  opacity: 1;
}

/* Shimmer button */
.banner_login_part .btn-primary,
.al .btn-primary {
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #4f8cff, #6c5ce7) !important;
  border: none !important;
  border-radius: 14px !important;
  padding: 14px 28px !important;
  font-weight: 600 !important;
  font-size: 15px !important;
  letter-spacing: 0.5px !important;
  transition: all 0.3s ease !important;
  box-shadow: 0 4px 15px rgba(79, 140, 255, 0.35) !important;
}
.banner_login_part .btn-primary:hover,
.al .btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(79, 140, 255, 0.5) !important;
}
.banner_login_part .btn-primary::after,
.al .btn-primary::after {
  content: '';
  position: absolute;
  top: -50%;
  left: -60%;
  width: 40%;
  height: 200%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  transform: skewX(-20deg);
  animation: shimmer 3s ease-in-out infinite;
}
@keyframes shimmer {
  0% { left: -60%; }
  100% { left: 140%; }
}

/* Banner content text */
.banner_content h1 {
  background: linear-gradient(135deg, #ffffff, #c8d6ff, #ffffff);
  background-size: 200% auto;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: textShine 4s linear infinite;
  font-weight: 800 !important;
}
@keyframes textShine {
  0% { background-position: 0% center; }
  100% { background-position: 200% center; }
}
.banner_content p {
  color: rgba(255, 255, 255, 0.7) !important;
  line-height: 1.8 !important;
}
.banner_content small {
  color: rgba(255, 255, 255, 0.6) !important;
}

/* === ENTRANCE ANIMATIONS === */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeInLeft {
  from { opacity: 0; transform: translateX(-40px); }
  to { opacity: 1; transform: translateX(0); }
}
@keyframes fadeInRight {
  from { opacity: 0; transform: translateX(40px); }
  to { opacity: 1; transform: translateX(0); }
}
@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.anim-fade-up { animation: fadeInUp 0.8s ease both; }
.anim-fade-left { animation: fadeInLeft 0.8s ease both; }
.anim-fade-right { animation: fadeInRight 0.8s ease both; }
.anim-scale-in { animation: scaleIn 0.6s ease both; }
.anim-fade-in { animation: fadeIn 0.8s ease both; }

.anim-delay-1 { animation-delay: 0.1s; }
.anim-delay-2 { animation-delay: 0.2s; }
.anim-delay-3 { animation-delay: 0.3s; }
.anim-delay-4 { animation-delay: 0.4s; }
.anim-delay-5 { animation-delay: 0.5s; }
.anim-delay-6 { animation-delay: 0.6s; }
.anim-delay-7 { animation-delay: 0.7s; }
.anim-delay-8 { animation-delay: 0.8s; }

/* Scroll-triggered animations */
[data-tl-animate] {
  opacity: 0;
  transition: all 0.7s cubic-bezier(0.4, 0, 0.2, 1);
}
[data-tl-animate].tl-visible {
  opacity: 1;
}
[data-tl-animate="fade-up"] {
  transform: translateY(40px);
}
[data-tl-animate="fade-up"].tl-visible {
  transform: translateY(0);
}
[data-tl-animate="fade-left"] {
  transform: translateX(-40px);
}
[data-tl-animate="fade-left"].tl-visible {
  transform: translateX(0);
}
[data-tl-animate="fade-right"] {
  transform: translateX(40px);
}
[data-tl-animate="fade-right"].tl-visible {
  transform: translateX(0);
}
[data-tl-animate="scale-up"] {
  transform: scale(0.85);
}
[data-tl-animate="scale-up"].tl-visible {
  transform: scale(1);
}
[data-tl-animate="fade-in"] {
  transform: none;
}

/* === COUNTER SECTION === */
#counter {
  padding: 60px 0;
  position: relative;
}
.counter__item {
  background: rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 20px !important;
  padding: 30px 15px !important;
  transition: all 0.4s ease !important;
}
.counter__item:hover {
  transform: translateY(-8px);
  background: rgba(255, 255, 255, 0.06);
  box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2);
}
.counter__item .icon {
  background: linear-gradient(135deg, #4f8cff, #6c5ce7) !important;
  box-shadow: 0 4px 20px rgba(79, 140, 255, 0.3) !important;
  transition: transform 0.3s ease !important;
}
.counter__item:hover .icon {
  transform: scale(1.1) rotate(5deg);
}

/* === ABOUT SECTION === */
#about_us {
  padding: 80px 0;
}
#about_us .def_image img {
  border-radius: 20px;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
  transition: transform 0.5s ease;
}
#about_us .def_image img:hover {
  transform: scale(1.03);
}
#about_us h2 {
  position: relative;
  display: inline-block;
}
#about_us h2::after {
  content: '';
  position: absolute;
  bottom: -10px;
  left: 0;
  width: 60px;
  height: 4px;
  background: linear-gradient(90deg, #4f8cff, #6c5ce7);
  border-radius: 2px;
}

/* === SERVICES SECTION === */
#services {
  padding: 80px 0;
  position: relative;
}
.social_media_btn.nav-link {
  background: rgba(255, 255, 255, 0.04) !important;
  border: 1px solid rgba(255, 255, 255, 0.08) !important;
  border-radius: 16px !important;
  padding: 12px 18px !important;
  transition: all 0.3s ease !important;
  position: relative;
  overflow: hidden;
}
.social_media_btn.nav-link::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(79,140,255,0.15), rgba(108,92,231,0.15));
  opacity: 0;
  transition: opacity 0.3s ease;
  border-radius: 16px;
}
.social_media_btn.nav-link:hover::before,
.social_media_btn.nav-link.active::before {
  opacity: 1;
}
.social_media_btn.nav-link.active {
  border-color: rgba(79, 140, 255, 0.4) !important;
  box-shadow: 0 0 20px rgba(79, 140, 255, 0.15) !important;
}
.social_media_btn.nav-link .icon {
  transition: transform 0.3s ease;
}
.social_media_btn.nav-link:hover .icon {
  transform: scale(1.15);
}
.box_item {
  background: rgba(255, 255, 255, 0.03) !important;
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.06) !important;
  border-radius: 20px !important;
  transition: all 0.4s ease !important;
  overflow: hidden;
}
.box_item:hover {
  background: rgba(255, 255, 255, 0.06) !important;
  border-color: rgba(79, 140, 255, 0.2) !important;
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.2) !important;
}
.service_content h3 {
  background: linear-gradient(135deg, #fff, #a8c0ff);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* === HOW IT WORKS SECTION === */
#featuresOfSmmpanel {
  padding: 80px 0;
}
.service_itemscard {
  border-radius: 20px !important;
  overflow: hidden;
  transition: all 0.4s ease !important;
}
.service_card_inner {
  background: rgba(255, 255, 255, 0.03) !important;
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.06) !important;
  border-radius: 20px !important;
  padding: 30px !important;
  transition: all 0.4s ease !important;
  height: 100%;
  position: relative;
  overflow: hidden;
}
.service_card_inner::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 4px;
  height: 0;
  background: linear-gradient(180deg, #4f8cff, #6c5ce7);
  border-radius: 0 2px 2px 0;
  transition: height 0.5s ease;
}
.service_card_inner:hover::before {
  height: 100%;
}
.service_card_inner:hover {
  background: rgba(255, 255, 255, 0.06) !important;
  border-color: rgba(79, 140, 255, 0.2) !important;
  transform: translateY(-6px);
  box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2);
}
.service_card_inner .icon {
  transition: transform 0.3s ease;
}
.service_card_inner:hover .icon {
  transform: scale(1.15);
}

/* === WHOLESALE SECTION === */
#wholesale {
  padding: 80px 0;
}
#wholesale .box_item {
  padding: 30px !important;
  border-radius: 20px !important;
}
#wholesale .box_item:hover {
  transform: translateY(-8px);
}
#wholesale .box_icon {
  transition: transform 0.4s ease;
}
#wholesale .box_item:hover .box_icon {
  transform: translateY(-6px);
}

/* === TESTIMONIALS SECTION === */
#testimonials {
  padding: 80px 0;
}
.testimonial_box {
  background: rgba(255, 255, 255, 0.04) !important;
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.08) !important;
  border-radius: 20px !important;
  padding: 30px !important;
  transition: all 0.4s ease !important;
}
.testimonial_box:hover {
  background: rgba(255, 255, 255, 0.07) !important;
  border-color: rgba(79, 140, 255, 0.2) !important;
  transform: translateY(-4px);
}
.testimonials_slider_button .swiper-prev,
.testimonials_slider_button .swiper-next {
  background: rgba(255, 255, 255, 0.06) !important;
  border: 1px solid rgba(255, 255, 255, 0.1) !important;
  border-radius: 50% !important;
  width: 50px !important;
  height: 50px !important;
  display: flex !important;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease !important;
  cursor: pointer;
}
.testimonials_slider_button .swiper-prev:hover,
.testimonials_slider_button .swiper-next:hover {
  background: rgba(79, 140, 255, 0.15) !important;
  border-color: rgba(79, 140, 255, 0.3) !important;
  transform: scale(1.1);
}

/* === WHY CHOOSE US === */
#whyChooseUs {
  padding: 80px 0;
}
.type_item_1 {
  background: rgba(255, 255, 255, 0.03) !important;
  border: 1px solid rgba(255, 255, 255, 0.06) !important;
  border-radius: 16px !important;
  padding: 24px !important;
  transition: all 0.4s ease !important;
}
.type_item_1:hover {
  background: rgba(255, 255, 255, 0.06) !important;
  border-color: rgba(79, 140, 255, 0.2) !important;
  transform: translateX(8px);
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
}
.type_item_1 .icon {
  transition: transform 0.3s ease;
}
.type_item_1:hover .icon {
  transform: rotate(10deg) scale(1.1);
}
#whyChooseUs .def_content h2 {
  position: relative;
  display: inline-block;
}
#whyChooseUs .def_content h2::after {
  content: '';
  position: absolute;
  bottom: -10px;
  left: 0;
  width: 60px;
  height: 4px;
  background: linear-gradient(90deg, #4f8cff, #6c5ce7);
  border-radius: 2px;
}

/* === EASY & ACCESSIBLE === */
#easyAndAccessible {
  padding: 80px 0;
}
#easyAndAccessible .def_image img {
  border-radius: 20px;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
  transition: transform 0.5s ease;
}
#easyAndAccessible .def_image img:hover {
  transform: scale(1.03) rotate(1deg);
}

/* === FEATURES SECTION === */
.features_box_item {
  padding: 24px !important;
}

/* === PAYMENT METHODS === */
#payment_methods {
  padding: 60px 0;
}
.payment_logo {
  opacity: 0.5;
  transition: all 0.3s ease !important;
  filter: grayscale(50%);
}
.payment_logo:hover {
  opacity: 1 !important;
  filter: grayscale(0%);
  transform: scale(1.15);
}

/* === BENEFITS SECTION === */
#benifits {
  padding: 80px 0;
}
.box_benifits {
  border-radius: 20px !important;
  padding: 30px !important;
  transition: all 0.4s ease !important;
}
.box_benifits:hover {
  transform: translateY(-10px) !important;
}
.box_benifits.mid_box:hover {
  transform: translateY(-12px) !important;
}
.box_benifits .box_icon {
  transition: transform 0.3s ease;
}
.box_benifits:hover .box_icon {
  transform: scale(1.1) translateY(-4px);
}

/* === FAQ SECTION === */
#faq {
  padding: 80px 0;
}
.faq_accordion .accordion-item {
  background: rgba(255, 255, 255, 0.03) !important;
  border: 1px solid rgba(255, 255, 255, 0.06) !important;
  border-radius: 16px !important;
  margin-bottom: 12px !important;
  overflow: hidden;
  transition: all 0.3s ease;
}
.faq_accordion .accordion-item:hover {
  border-color: rgba(79, 140, 255, 0.2) !important;
}
.faq_accordion .accordion-button {
  background: transparent !important;
  color: #fff !important;
  font-weight: 600;
  padding: 18px 24px !important;
  box-shadow: none !important;
}
.faq_accordion .accordion-button:not(.collapsed) {
  background: rgba(79, 140, 255, 0.08) !important;
  color: #a8c0ff !important;
}
.faq_accordion .accordion-button::after {
  filter: brightness(0) invert(1);
}
.faq_accordion .accordion-body {
  background: rgba(255, 255, 255, 0.02) !important;
  color: rgba(255, 255, 255, 0.7) !important;
  padding: 16px 24px !important;
  border-top: 1px solid rgba(255, 255, 255, 0.05) !important;
}
#faq .def_content h2 {
  position: relative;
  display: inline-block;
}
#faq .def_content h2::after {
  content: '';
  position: absolute;
  bottom: -10px;
  left: 0;
  width: 60px;
  height: 4px;
  background: linear-gradient(90deg, #4f8cff, #6c5ce7);
  border-radius: 2px;
}

/* === RESELLER SECTION === */
#whatWeDo {
  padding: 80px 0;
}
#whatWeDo .box_item {
  padding: 30px !important;
  border-radius: 20px !important;
  transition: all 0.4s ease !important;
}
#whatWeDo .box_item:hover {
  transform: translateY(-6px);
  border-color: rgba(79, 140, 255, 0.2) !important;
}

/* === SECTION HEADINGS === */
.def_content h2 {
  position: relative;
  display: inline-block;
}
.def_content.text-center h2::after {
  content: '';
  position: absolute;
  bottom: -12px;
  left: 50%;
  transform: translateX(-50%);
  width: 60px;
  height: 4px;
  background: linear-gradient(90deg, #4f8cff, #6c5ce7);
  border-radius: 2px;
}

/* === GENERAL ENHANCEMENTS === */
.btn-primary {
  background: linear-gradient(135deg, #4f8cff, #6c5ce7) !important;
  border: none !important;
  border-radius: 12px !important;
  transition: all 0.3s ease !important;
  box-shadow: 0 4px 15px rgba(79, 140, 255, 0.25) !important;
}
.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(79, 140, 255, 0.4) !important;
}

/* Day mode adjustments */
.daymode .banner_login_part {
  background: rgba(255, 255, 255, 0.7) !important;
  border-color: rgba(0, 0, 0, 0.08) !important;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1) !important;
}
.daymode .banner_login_part h4 {
  background: linear-gradient(135deg, #1a1a3e, #4f8cff);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.daymode .banner_login_part .form-control {
  background: rgba(255, 255, 255, 0.8) !important;
  border-color: rgba(0, 0, 0, 0.1) !important;
  color: #1a1a3e !important;
}
.daymode .banner_login_part .form-control::placeholder {
  color: rgba(0, 0, 0, 0.35) !important;
}

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
  [data-tl-animate] {
    opacity: 1 !important;
    transform: none !important;
  }
}

/* Mobile responsive */
@media (max-width: 991px) {
  .banner_login_part {
    margin-top: 30px;
    padding: 30px 20px !important;
  }
  .banner_content {
    text-align: center !important;
  }
  .banner_content h1 {
    font-size: 1.8rem !important;
  }
}
@media (max-width: 575px) {
  .banner_login_part {
    padding: 24px 16px !important;
    border-radius: 18px !important;
  }
  .counter__item {
    padding: 20px 10px !important;
    margin-bottom: 12px;
  }
}

/* Glow effect for section separators */
section {
  position: relative;
}
section::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 10%;
  width: 80%;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(79, 140, 255, 0.15), transparent);
}
section:last-of-type::after {
  display: none;
}
</style>

       	            <main class="no_auth">
          		     <!-- Banner Section -->
 <section id="banner">
  <div class="banner_bg_effect">
    <img
      src="https://cdn.smmpanelbdlab.com/smmscript/smmrx/img/ln8x4fsqd7nhg7q0.png"
      class="img-fluid bg_banner_left_effect"
      alt="bg left"
    />
    <img
      src="https://cdn.smmpanelbdlab.com/smmscript/smmrx/img/0h19wpmlpznb1kq7.png"
      class="img-fluid bg_banner_right_effect"
      alt="bg right"
    />
  </div>

      
		<style>
    .size {
     width: 100% !important;
     white-space: nowrap !important;
     margin-top: -7px !important;
     padding: 10px !important;
     margin-bottom: 0px !important;
     display: flex !important;
     z-index: 9999999 !important;
   }
  
  .d-flex {
    display: flex !important;
    gap: 10px !important;
    width: 100% !important;
  }
.google-login-wrap {
	position: relative;
	border-radius: 10px;
	background-color: var(--primary-color);
	border-color: var(--primary-color-deep);
	align-items: center;
	align-content: center;
}
  .google-login {
	color: #FFF;
	font-size: 14px;
	font-weight: 500;
	display: flex;
	flex-wrap: wrap;
	align-items: center;
	align-content: center;
}
  .google-btn {
	position: absolute;
	left: 0;
	right: 0;
	top: 50%;
	transform: translateY(-50%);
	height: 55px;
	width: 100%;
	overflow: hidden;
	opacity: 0;
}
  .google-login svg {
	width: 20px;
	display: inline-block;
	margin-left: 8px;
}
.btn-secondary {
    --bs-btn-bg: #6c757d00 !important;
    --bs-btn-border-color: #6c757d00 !important;
}
@media (max-width:591.98px) {
    .nav_servicess .nav-link .text {
       display: none !important;
	}
}
 
  .al, .nav_servicess .nav-link {
    align-items: center !important;
    justify-content: flex !important;
    text-align: center !important;
  }
/* Typewriter effect 1 */
@keyframes typing {
  0%, 10% { content: ""; }
  10%, 20% { content: "O"; }
  25%, 40% { content: "Ou"; }
  50%, 65% { content: "Our"; }
  75%, 80% { content: "Our Si"; }
  100%, 100% { content: "Our Site"; }
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}
.typewriter {
  --caret: currentcolor;
} 
.typewriter::before {
  content: "";
  animation: typing 1s steps(9, end) infinite; /* Faster typing animation */
}
.typewriter::after {
  content: "";
  border-right: 1px solid var(--caret);
  animation: blink 0.3s linear infinite;
}
.typewriter.thick::after {
  border-right: 1ch solid var(--caret);
}
.typewriter.nocaret::after {
  border-right: 0;
}
   body .tp {
    margin-top: 10px !important;
  }
