    padding-left: 4px !important;
  }
.daymode .nav_servicess .nav-link {
    background-color: #F2FFFF !important;
  border: 1px solid #D4FFFF !important;
    color: var(--form-input-bg) !important;
  }
 body .nav_servicess .nav-link .text, .daymode .nav_servicess .nav-link.active .text {
   color: #fff !important; 
  }
  html body .social_media_wrap .nav-link.active {
     border: 1px solid var(--primary-color) !important;
    color: #fff !important;
  }
  .daymode .nav_servicess .nav-link .text {
   color: var(--form-input-bg) !important; 
  }
  body .nav_servicess {
    background: #232323 !important;
   padding: 12px !important;
   
  }*/
   html body .social_media_wrap .nav-link.active {
     border: 1px solid var(--primary-color) !important;
    
  }
@media (prefers-reduced-motion) {
  .typewriter::after {
    animation: none;
  }
  @keyframes sequencePopup {
    0%, 100% { content: "{{ site['site_name'] }}}"; }
    25% { content: "{{ site['site_name'] }}}"; }
    50% { content: "{{ site['site_name'] }}}"; }
    75% { content: "{{ site['site_name'] }}}"; }
  }
  .typewriter::before {
    content: "developer";
    animation: sequencePopup 3s linear infinite;
  }
}
  
 html body .abh {
   color: var(--primary-color) !important; 
  }
