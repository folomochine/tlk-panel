        <div style="flex:1;min-width:0">
          <h3 class="tl-popup-title" id="tlPopupOrderTitle">Commande #{{ data['order']['id'] }} envoyée</h3>
          <span class="tl-popup-sub">Prise en compte avec succès</span>
        </div>
      </div>
      <div class="tl-popup-body">
        Votre commande a bien été enregistrée. Suivez son avancement dans <strong>Mes commandes</strong>.
        <div class="tl-popup-list">
          <div class="r"><span class="k">{{ lang["neworder.success.service"] }}</span><span class="v" title="{{ data['order']['service'] }}">{{ data['order']['service'] }}</span></div>
          <div class="r"><span class="k">{{ lang["neworder.success.quantity"] }}</span><span class="v">{{ data['order']['quantity'] }}</span></div>
          <div class="r"><span class="k">{{ lang["neworder.success.charge"] }}</span><span class="v">{{ data['order']['price'] }}</span></div>
          <div class="r"><span class="k">{{ lang["neworder.success.balance"] }}</span><span class="v">{{ data['order']['balance'] }}</span></div>
        </div>
      </div>
      <div class="tl-popup-actions">
        <button type="button" class="tl-popup-btn g" onclick="tlClosePopupOrder()">Continuer</button>
        <a class="tl-popup-btn p" href="/orders"><i class="fa fa-list"></i> Mes commandes</a>
      </div>
    </div>
  </div>
{% endif %}

{% if data["order"]["success"] == 2 %}
  <div class="tl-popup-overlay" id="tl-popup-order" role="presentation">
    <div class="tl-popup ok" role="dialog" aria-modal="true" aria-labelledby="tlPopupOrderTitle">
      <button type="button" class="tl-popup-close" onclick="tlClosePopupOrder()" aria-label="Fermer">✕</button>
      <div class="tl-popup-header">
        <div class="tl-popup-ico"><i class="fa fa-sync-alt"></i></div>
        <div style="flex:1;min-width:0">
          <h3 class="tl-popup-title" id="tlPopupOrderTitle">Abonnement #{{ data['order']['id'] }} créé</h3>
