.tl-qty-box{padding:10px 12px;border-radius:10px;font-size:12px;line-height:1.6}
.tl-qty-box.good{background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.2)}
.tl-qty-box.bad{background:rgba(239,68,68,.07);border:1px solid rgba(239,68,68,.2)}
.tl-qty-box strong{display:block;font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px}
.tl-qty-box.good strong{color:#16a34a}
.tl-qty-box.bad strong{color:#dc2626}
