<style>
/* ===== ToutLike : popup compact mobile-first (commande) ===== */
.tl-popup-overlay{
  position:fixed;inset:0;z-index:99998;
  background:rgba(15,23,42,.55);
  -webkit-backdrop-filter:blur(4px);backdrop-filter:blur(4px);
  display:flex;align-items:flex-end;justify-content:center;
  padding:12px;
  animation:tlPopupFadeIn .22s ease-out;
}
.tl-popup{
  position:relative;width:100%;max-width:420px;
  background:#fff;color:#0f172a;
  border:1px solid rgba(148,163,184,.25);
  border-radius:20px 20px 22px 22px;
  box-shadow:0 20px 60px -10px rgba(0,0,0,.40);
  overflow:hidden;
  padding-bottom:env(safe-area-inset-bottom,0);
  animation:tlPopupSlideUp .28s cubic-bezier(.34,1.56,.64,1);
}
body.dark-mode .tl-popup{background:#0f172a;color:#f1f5f9;border-color:rgba(148,163,184,.18)}
.tl-popup-header{
  display:flex;align-items:center;gap:12px;
  padding:18px 56px 10px 20px;
}
.tl-popup-ico{
  width:46px;height:46px;border-radius:14px;flex-shrink:0;
  display:inline-flex;align-items:center;justify-content:center;
  font-size:20px;color:#fff;
}
.tl-popup.ok .tl-popup-ico{background:linear-gradient(135deg,#10B981,#06B6D4);box-shadow:0 10px 22px rgba(16,185,129,.35)}
.tl-popup.err .tl-popup-ico{background:linear-gradient(135deg,#EF4444,#FB7185);box-shadow:0 10px 22px rgba(239,68,68,.35)}
.tl-popup-title{font-size:16px;font-weight:800;line-height:1.3;margin:0;flex:1;min-width:0;color:inherit}
.tl-popup-sub{display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#64748b;margin-top:2px}
body.dark-mode .tl-popup-sub{color:#94a3b8}
.tl-popup-close{
  position:absolute;top:12px;right:12px;
  width:34px;height:34px;min-width:34px;border:0;cursor:pointer;
  border-radius:10px;background:rgba(148,163,184,.14);color:inherit;
  display:inline-flex;align-items:center;justify-content:center;
  font-size:15px;line-height:1;transition:all .15s ease;
}
.tl-popup-close:hover{background:rgba(148,163,184,.28)}
body.dark-mode .tl-popup-close{background:rgba(148,163,184,.18);color:#e2e8f0}
.tl-popup-body{
  padding:2px 20px 14px;font-size:14px;line-height:1.55;
  color:#475569;word-break:break-word;
}
body.dark-mode .tl-popup-body{color:#cbd5e1}
.tl-popup-body strong{color:#0f172a;font-weight:800}
body.dark-mode .tl-popup-body strong{color:#f1f5f9}
.tl-popup-list{display:flex;flex-direction:column;gap:6px;margin:12px 0 2px}
.tl-popup-list .r{
  display:flex;align-items:center;justify-content:space-between;gap:10px;
  padding:9px 12px;border-radius:10px;
  background:rgba(15,23,42,.04);
}
body.dark-mode .tl-popup-list .r{background:rgba(148,163,184,.08)}
.tl-popup-list .r .k{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.04em;color:#64748b}
.tl-popup-list .r .v{font-size:13px;font-weight:700;color:#0f172a;max-width:60%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;direction:ltr}
body.dark-mode .tl-popup-list .r .v{color:#f1f5f9}
body.dark-mode .tl-popup-list .r .k{color:#94a3b8}
.tl-popup-actions{
  display:flex;gap:8px;padding:12px 16px 16px;
  border-top:1px solid rgba(148,163,184,.18);
  background:rgba(248,250,252,.6);
}
body.dark-mode .tl-popup-actions{background:rgba(15,23,42,.35);border-top-color:rgba(148,163,184,.14)}
.tl-popup-btn{
  flex:1;display:inline-flex;align-items:center;justify-content:center;gap:6px;
  padding:12px 14px;border-radius:12px;font-weight:800;font-size:13px;
  text-decoration:none;border:0;cursor:pointer;transition:all .15s ease;
  min-height:44px;line-height:1;
}
.tl-popup-btn.g{background:rgba(148,163,184,.18);color:#0f172a}
body.dark-mode .tl-popup-btn.g{background:rgba(148,163,184,.22);color:#e2e8f0}
.tl-popup-btn.g:hover{background:rgba(148,163,184,.28)}
.tl-popup.ok .tl-popup-btn.p{background:linear-gradient(135deg,#10B981,#06B6D4);color:#fff;box-shadow:0 10px 22px rgba(16,185,129,.30)}
.tl-popup.err .tl-popup-btn.p{background:linear-gradient(135deg,#EF4444,#FB7185);color:#fff;box-shadow:0 10px 22px rgba(239,68,68,.30)}
.tl-popup-btn.p:hover{filter:brightness(1.08)}
@keyframes tlPopupFadeIn{from{opacity:0}to{opacity:1}}
@keyframes tlPopupSlideUp{from{transform:translateY(100%);opacity:0}to{transform:translateY(0);opacity:1}}
@keyframes tlPopupFadeOut{to{opacity:0}}
@keyframes tlPopupSlideDown{to{transform:translateY(100%);opacity:0}}
.tl-popup-overlay.-closing{animation:tlPopupFadeOut .2s ease-in forwards}
.tl-popup-overlay.-closing .tl-popup{animation:tlPopupSlideDown .2s ease-in forwards}
/* Desktop : modal centré avec scale */
@media (min-width:640px){
  .tl-popup-overlay{align-items:center;padding:24px}
  .tl-popup{border-radius:20px;animation:tlPopupScale .22s cubic-bezier(.34,1.56,.64,1)}
  .tl-popup-overlay.-closing .tl-popup{animation:tlPopupScaleOut .18s ease-in forwards}
  @keyframes tlPopupScale{from{transform:scale(.92);opacity:0}to{transform:scale(1);opacity:1}}
  @keyframes tlPopupScaleOut{to{transform:scale(.96);opacity:0}}
}
</style>

{% if error %}
  <div class="tl-popup-overlay" id="tl-popup-order" role="presentation">
    <div class="tl-popup err" role="dialog" aria-modal="true" aria-labelledby="tlPopupOrderTitle">
      <button type="button" class="tl-popup-close" onclick="tlClosePopupOrder()" aria-label="Fermer">✕</button>
      <div class="tl-popup-header">
        <div class="tl-popup-ico"><i class="fa fa-exclamation-triangle"></i></div>
        <div style="flex:1;min-width:0">
          <h3 class="tl-popup-title" id="tlPopupOrderTitle">Commande impossible</h3>
          <span class="tl-popup-sub">Erreur lors de la soumission</span>
        </div>
      </div>
      <div class="tl-popup-body">{{ errorText }}</div>
      <div class="tl-popup-actions">
        <button type="button" class="tl-popup-btn g" onclick="tlClosePopupOrder()">Fermer</button>
        {% if errorText matches '/[Ss]olde insuffisant|not enough|notenough/' %}
          <a class="tl-popup-btn p" href="/addfunds"><i class="fa fa-wallet"></i> Recharger</a>
        {% else %}
          <button type="button" class="tl-popup-btn p" onclick="tlClosePopupOrder()"><i class="fa fa-check"></i> Compris</button>
        {% endif %}
      </div>
    </div>
  </div>
{% endif %}

{% if data["order"]["success"] == 1 %}
