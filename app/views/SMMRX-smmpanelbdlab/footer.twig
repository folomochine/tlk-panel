       <script>
    function filterBySearch(getTargetItem) {
        const filterServicesInput = document.getElementById('filterServicesInput');
        const nothingFound = document.querySelector('.nothing-found');
        const searchTextWrite = document.getElementById('search-text-write');

        if (!getTargetItem) return; // Avoid errors if input is empty or undefined.

        $('.service_item').each(function () {
            var text = $(this).text().toLowerCase();
            if (text.indexOf(getTargetItem.toLowerCase()) === -1) {
                $(this).addClass('hidden');
            } else {
                $(this).removeClass('hidden');
            }
        });

        const catCards = document.querySelectorAll('.serv_category_card');
        catCards.forEach(card => {
            const items = card.querySelectorAll('.service_item');
            const itemsHidden = card.querySelectorAll('.service_item.hidden');

            if (itemsHidden.length === items.length) {
                card.style.display = 'none';
                card.classList.add('empty');
            } else {
                card.style.display = '';
                card.classList.remove('empty');
            }
        });

        const emptyCards = document.querySelectorAll('.serv_category_card.empty');

        if (nothingFound && searchTextWrite) {
            if (emptyCards.length === catCards.length) {
                nothingFound.style.display = '';
                searchTextWrite.innerHTML = getTargetItem;
            } else {
                nothingFound.style.display = 'none';
                searchTextWrite.innerHTML = '';
            }
        }
    }

    document.getElementById('servicesFilterWraper').addEventListener('click', function (e) {
        const getallActive = document.getElementsByClassName('activeItem');
        for (let item of getallActive) { // Fixed `for (item of getallActive)`
            item.classList.remove('activeItem');
        }
        e.target.classList.add('activeItem');
    });
</script>

   
