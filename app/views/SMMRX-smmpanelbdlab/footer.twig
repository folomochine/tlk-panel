          $(document).ready(function() {
            // Initialize popovers
            var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="popover"]'));
            var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
              return new bootstrap.Popover(popoverTriggerEl);
            });
        
            // Click event for each button
            $('.copyButton').click(function() {
              var valueToCopy = $(this).data('value');
              copyToClipboardAndShowPopover(valueToCopy, this);
            });
        
            // Function to copy to clipboard and show popover
            function copyToClipboardAndShowPopover(value, buttonElement) {
              var tempTextarea = $('<textarea>');
              $('body').append(tempTextarea);
              tempTextarea.val(value).select();
              try {
                document.execCommand('copy');
                var popover = bootstrap.Popover.getInstance(buttonElement);
                popover.show();
                setTimeout(function() {
                  popover.hide();
                }, 2000);
              } catch (err) {
                console.error('Failed to copy: ', err);
              }
              tempTextarea.remove();
            }
          });
        </script>
