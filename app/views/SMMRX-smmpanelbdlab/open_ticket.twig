 {% include 'header.twig' %}
 <!-- Ticket Chat Page --><!-- Main variables *content* -->
        <main class="auth">
                    <div class="about_us_effect">
            <img
              src="https://cdn.smmpanelbdlab.com/work/PerfectPanel/img/bg-img1.png"
              class="img-fluid about_us_img_left"
              alt=""
            />
            <img
              src="https://cdn.smmpanelbdlab.com/work/PerfectPanel/img/bg-img2.png"
              class="img-fluid about_us_img_right"
              alt=""
            />
          </div>
 <section id="ticketChat">
    <div class="container-fluid">
        <div class="row">
          <div class="col-lg-4 col-md-4 col-12 mb-3">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="ticket_subject">Tickets Info</h4>
                </div>
<div class="card">
              <div class="card-body">
                <div class="ticket_info_item">
                  <div class="left">Ticket Id</div>
                  <div class="right">{{ messageList['ticket']['ticket_id'] }}</div>
                </div>
                <div class="ticket_info_item">
                  <div class="left">Priority</div>
                  <div class="right">High</div>
                </div>
                <div class="ticket_info_item">
                  <div class="left">Department</div>
                  <div class="right">Support</div>
                </div>
                <div class="ticket_info_item">
                  <div class="left">Response Time</div>
                  <div class="right">0-2H</div>
                </div>
                <div class="ticket-info-note">
                  NOTE: Sometimes it can take up to 6 hours for us to respond, depending on the tickets overload.
                </div>
              </div>
            </div>
          </div>
      {% if error %}
        <div class="alert alert-dismissible alert-danger">
          <button type="button" class="close" data-dismiss="alert">×</button>
          {{ errorText }}
        </div>
      {% endif %}
      {% if success %}
        <div class="alert alert-dismissible alert-success">
          <button type="button" class="close" data-dismiss="alert">×</button>
          {{ successText }}
        </div>
      {% endif %}
 <div class="col-lg-8 col-md-8 col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="ticket_subject">{{ messageList['ticket']['subject'] }}</h4>{% if messageList["ticket"]["canmessage"] == 1 %} <span class="badge"> This request has been closed by the administrator</span></div> {% endif %}
                    <a href="/tickets" class="btn btn-primary btn-sm">Back</a>
                </div>
<div class="card card_chat mb-5">
                    <div class="card-body">
                        <div id="allChat">
              {% if messageList %}
                {% for message in messageList %}
                  {% if message["support"] == 1 %}
<div class="row ticket-message-block ticket-message-right user_ticket">
                              <div class="col-md-4 col-12"></div>
                              <div class="col-md-8 col-12">
                                <div class="ticket-message">
                    <div class="message">{{ message["message"] }}</div>
                                            </div>
                                <div class="info text-right">
                                  <strong>{{ user["username"] }}</strong>
                                  <small class="text-muted">{{ message["time"] }}</small>
                                </div>
                              </div>
                    </div>
                  {% elseif message["subject"] %}
                  {% else %}
                    
<div class="row ticket-message-block ticket-message-left admin_ticket">
                              <div class="col-md-8 col-12">
                                <div class="ticket-message">
                                  <div class="message">{{ message["message"] }}</div>
                                                                  </div>
                                <div class="info">
                                  <strong>Support</strong>
                                                <div class="text-muted">{{ message["time"] }}</div>
                                            </div>
                                        </div>
                                                                   
                            
                      </div>
                  {% endif %}

                {% endfor %}
              {% endif %}
            {% if messageList['ticket']['canmessage'] == 2 %}
              <div class="row">
                  <div class="col-md-12">
                    <form method="post" action="tickets/{{ messageList['ticket']['ticket_id'] }}">
                {{ csrf_field() }}
                      <div class="form-group panel-border-top"><br>
                        <label for="message" class="control-label">Message</label>
                        <textarea id="message" rows="5" class="form-control" name="message">{{ data["message"] }}</textarea>
                      </div><br>
                      <button type="submit" class="btn btn-primary">Submit</button>
                    </form>
                  </div>
                </div>
             
            {% endif %}

</div></div></div></div></div></div></div></div></div></div></div>
{% include 'footer.twig' %}
